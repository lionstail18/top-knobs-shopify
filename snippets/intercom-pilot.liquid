{%- comment -%}
  intercom-pilot.liquid (TOP KNOBS variant) — EVALUATION ONLY, sticky-gated.

  Top Knobs already runs the OFFICIAL Intercom Shopify app (app embed in
  settings_data.json). That app boots the Messenger site-wide and handles
  logged-in identity + order history on its own. This snippet therefore
  does NOT load or boot Intercom and does NOT re-identify the user — it
  only ENRICHES the identity the app already established with the live
  cart / browsing context the app does not capture.

  STICKY GATE: visiting any URL once with ?intercom_pilot=1 arms the
  pilot for the whole browser (localStorage) so it survives normal
  navigation. ?intercom_pilot=0 disarms it. With nothing armed this
  snippet does nothing — zero impact on normal visitors; one-line revert.
{%- endcomment -%}
<script>
(function () {
  var KEY = 'intercom_pilot';
  try {
    var q = new URLSearchParams(window.location.search).get(KEY);
    if (q === '1') localStorage.setItem(KEY, '1');
    if (q === '0') localStorage.removeItem(KEY);
    if (localStorage.getItem(KEY) !== '1') return;
  } catch (e) { return; }

  function ic() { return (typeof window.Intercom === 'function') ? window.Intercom : null; }

  function supplementalAttrs() {
    var a = {};
    {%- if customer -%}
    a.trade_account = {{ customer.b2b? | default: false | json }};
    a.customer_tags = {{ customer.tags | join: ',' | json }};
    {%- if customer.b2b? and company -%}
    a.company_name = {{ company.name | json }};
    a.company_plan = "Trade";
    {%- endif -%}
    {%- endif -%}
    return a;
  }

  function pushCart() {
    fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        var items = cart.items || [];
        var lines = items.map(function (it) {
          return it.product_title
            + (it.variant_title ? ' / ' + it.variant_title : '')
            + ' x' + it.quantity
            + (it.sku ? ' (' + it.sku + ')' : '');
        });
        var snapshot = {
          cart_total: cart.total_price / 100,
          cart_item_count: cart.item_count,
          cart_currency: cart.currency,
          cart_contents: lines.join('; ').slice(0, 800),
          cart_skus: items.map(function (i) { return i.sku; }).join(',').slice(0, 500),
          current_page_type: {{ request.page_type | json }},
          current_page_url: window.location.href
        };
        var I = ic();
        if (!I) { console.log('[intercom-pilot] Intercom not ready, skipped push'); return; }
        var attrs = snapshot;
        var s = supplementalAttrs();
        for (var k in s) attrs[k] = s[k];
        // Custom attributes on the contact ...
        I('update', attrs);
        // ... plus a timeline event so it is unmistakably visible / verifiable.
        I('trackEvent', 'pilot_cart_snapshot', snapshot);
        console.log('[intercom-pilot] pushed cart snapshot', snapshot);
      })
      .catch(function (e) { console.log('[intercom-pilot] cart fetch failed', e); });
  }

  // Push when the Messenger is opened (guaranteed booted + tied to the live
  // conversation), plus timed retries to catch the post-boot window, plus
  // cart-change / focus re-pushes.
  function arm() {
    var I = ic();
    if (I) { try { I('onShow', pushCart); } catch (e) {} }
    [800, 2500, 5000, 9000].forEach(function (ms) { setTimeout(pushCart, ms); });
    ['cart:updated', 'cart:refresh', 'ajaxCart.afterCartLoad'].forEach(function (ev) {
      document.addEventListener(ev, pushCart);
    });
    window.addEventListener('focus', pushCart);

    {%- if request.page_type == 'product' and product -%}
    setTimeout(function () {
      var I2 = ic();
      if (I2) I2('trackEvent', 'viewed_product', {
        title: {{ product.title | json }},
        sku: {{ product.selected_or_first_available_variant.sku | json }},
        price: {{ product.price | divided_by: 100.0 | json }},
        url: window.location.href
      });
    }, 2500);
    {%- endif -%}
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', arm);
  } else { arm(); }
  console.log('[intercom-pilot] armed');
})();
</script>
