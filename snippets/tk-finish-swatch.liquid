  {%- when 'antique english' -%}{%- assign hex = '#4a3a2a' -%}
  {%- when 'flat white' -%}{%- assign hex = '#f5f5f0' -%}
  {%- when 'matte white' -%}{%- assign hex = '#f5f5f0' -%}
  {%- when 'white' -%}{%- assign hex = '#ffffff' -%}
  {%- when 'gunmetal' -%}{%- assign hex = '#2a3439' -%}
  {%- when 'graphite' -%}{%- assign hex = '#383838' -%}
