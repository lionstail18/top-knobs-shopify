  {%- when 'leather' -%}{%- assign hex = '#8b6b3d' -%}
  {%- when 'wood' -%}{%- assign hex = '#a0826d' -%}
  {%- when 'ash gray' -%}{%- assign hex = '#a8a59c' -%}
