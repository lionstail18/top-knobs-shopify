  {%- elsif normalized contains 'copper' -%}{%- assign hex = '#b87333' -%}
  {%- elsif normalized contains 'gold' -%}{%- assign hex = '#d4af37' -%}
  {%- elsif normalized contains 'silver' -%}{%- assign hex = '#bcbcb6' -%}
  {%- elsif normalized contains 'stainless' -%}{%- assign hex = '#a9a9a8' -%}
  {%- elsif normalized contains 'steel' -%}{%- assign hex = '#7a7a78' -%}
  {%- elsif normalized contains 'iron' -%}{%- assign hex = '#3a3936' -%}
  {%- elsif normalized contains 'aluminum' -%}{%- assign hex = '#b8b8b6' -%}
  {%- elsif normalized contains 'zinc' -%}{%- assign hex = '#a8a8a4' -%}
  {%- elsif normalized contains 'gunmetal' -%}{%- assign hex = '#2a3439' -%}
  {%- elsif normalized contains 'graphite' -%}{%- assign hex = '#383838' -%}
  {%- elsif normalized contains 'crystal' or normalized contains 'glass' -%}{%- assign hex = '#e8e8f0' -%}
  {%- elsif normalized contains 'porcelain' -%}{%- assign hex = '#faf8f3' -%}
  {%- elsif normalized contains 'oak' or normalized contains 'walnut' or normalized contains 'wood' or normalized contains 'maple' -%}{%- assign hex = '#a0826d' -%}
  {%- elsif normalized contains 'ash' -%}{%- assign hex = '#bcb6a8' -%}
  {%- elsif normalized contains 'champagne' -%}{%- assign hex = '#c8a76a' -%}
  {%- elsif normalized contains 'rose' -%}{%- assign hex = '#b76e79' -%}
  {%- elsif normalized contains 'verde' or normalized contains 'patina' -%}{%- assign hex = '#7a8a6b' -%}
  {%- elsif normalized contains 'slate' -%}{%- assign hex = '#525a62' -%}
  {%- elsif normalized contains 'sable' -%}{%- assign hex = '#352620' -%}
  {%- elsif normalized contains 'rust' -%}{%- assign hex = '#9c5a3a' -%}
  {%- elsif normalized contains 'gray' or normalized contains 'grey' -%}{%- assign hex = '#888a8c' -%}
  {%- elsif normalized contains 'blue' -%}{%- assign hex = '#3a5a8a' -%}
  {%- elsif normalized contains 'green' -%}{%- assign hex = '#5a7a4a' -%}
  {%- elsif normalized contains 'red' -%}{%- assign hex = '#a02a2a' -%}
  {%- elsif normalized contains 'orange' -%}{%- assign hex = '#e8702a' -%}
  {%- elsif normalized contains 'yellow' -%}{%- assign hex = '#e8c84a' -%}
  {%- elsif normalized contains 'pink' -%}{%- assign hex = '#e8a8b6' -%}
  {%- elsif normalized contains 'purple' or normalized contains 'lavender' or normalized contains 'magenta' -%}{%- assign hex = '#7a4a8a' -%}
  {%- elsif normalized contains 'brown' or normalized contains 'chocolate' or normalized contains 'espresso' -%}{%- assign hex = '#6a4a2a' -%}
  {%- elsif normalized contains 'almond' or normalized contains 'cream' or normalized contains 'tan' -%}{%- assign hex = '#dac9a8' -%}
  {%- elsif normalized contains 'natural' -%}{%- assign hex = '#c4b294' -%}
  {%- elsif normalized contains 'oil rubbed' -%}{%- assign hex = '#2a1a0e' -%}
  {%- elsif normalized contains 'wrought' -%}{%- assign hex = '#33302c' -%}
  {%- elsif normalized contains 'gun metal' -%}{%- assign hex = '#2a3439' -%}
  {%- elsif normalized contains 'english' -%}{%- assign hex = '#4a3a2a' -%}
  {%- elsif normalized contains 'lustre' or normalized contains 'luster' -%}{%- assign hex = '#b9b4a6' -%}
  {%- elsif normalized contains 'mink' -%}{%- assign hex = '#6f6259' -%}
  {%- elsif normalized contains 'turquoise' or normalized contains 'teal' -%}{%- assign hex = '#2fb6b6' -%}
  {%- elsif normalized contains 'antique' -%}{%- assign hex = '#8a7048' -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%}
  Tier 4 — never a bare letter. Any finish that still missed gets a
  neutral brushed-metal chip so it reads as a metal finish, not a
  placeholder. (Parity with knobs-finish-swatch; adapted to TK's
  single-span markup — once hex is set, tk-swatch--unknown and the
  initial-letter span below can't trigger.)
{%- endcomment -%}
{%- if hex == '' -%}
  {%- assign hex = 'linear-gradient(135deg,#cfcabd 0%,#a7a299 45%,#cfcabd 70%,#8f8a80 100%)' -%}
{%- endif -%}

<span class="tk-swatch{% if extra_class %} {{ extra_class }}{% endif %}{% if hex == '' %} tk-swatch--unknown{% endif %}"
      title="{{ finish_name | escape }}"
      style="--tk-swatch-size: {{ size_val }}px;{% if hex != '' %} background: {{ hex }};{% endif %}"
      data-finish="{{ normalized | escape }}">
  {%- if hex == '' -%}
    {%- assign initial = finish_name | slice: 0, 1 | upcase -%}
    <span class="tk-swatch__initial">{{ initial }}</span>
  {%- endif -%}
</span>
