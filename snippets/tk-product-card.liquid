{%- comment -%}
  Finish-aware card image (parity with knobs-product-card). When a finish
  context is supplied (card_finish_class — set by tk-collection.liquid on
  finish-* pages / a single active Finish filter), lead with that finish's
  photo: precomputed map metafield custom.finish_class_image → else first
  variant whose Finish option contains the class keyword → that variant's
  linked image or the product image whose filename carries the SKU code →
  else product.featured_image (also when no finish context, so non-finish
  grids keep the original zero-overhead path). Scans bounded to 80.
{%- endcomment -%}
{%- liquid
  assign card_image = product.featured_image
  assign card_image_url = ''
  if card_finish_class != blank
    assign kpc = product.metafields.custom.finish_class_image.value
    if kpc != blank
      assign kpc_u = kpc[card_finish_class]
      if kpc_u != blank
        assign card_image_url = kpc_u
      endif
    endif
    if card_image_url == blank
      assign kfc_alt = card_finish_class
      if card_finish_class == 'gray'
        assign kfc_alt = 'grey'
      endif
      assign fin_pos = 0
      for o in product.options
        assign ol = o | downcase
        if ol contains 'finish' or ol contains 'color' or ol contains 'colour'
          assign fin_pos = forloop.index
          break
        endif
      endfor
      if fin_pos > 0
        assign vmatch = blank
        assign vscan = 0
        for v in product.variants
          if vscan >= 80
            break
          endif
          assign vscan = vscan | plus: 1
          if fin_pos == 1
            assign fv = v.option1
          elsif fin_pos == 2
            assign fv = v.option2
          else
            assign fv = v.option3
          endif
          assign fvl = fv | downcase
          if fvl contains card_finish_class or fvl contains kfc_alt
            assign vmatch = v
            break
          endif
        endfor
        if vmatch != blank
          if vmatch.image != blank
            assign card_image = vmatch.image
          else
            assign sk = vmatch.sku | default: ''
            assign sk_segs = sk | split: '-'
            assign sk_tok = sk
            if sk_segs.size > 1
              assign sk_b = sk_segs | first
              assign sk_tok = sk | remove_first: sk_b | remove_first: '-'
            endif
            assign t_us = sk_tok | append: '_'
            assign t_dot = sk_tok | append: '.'
            assign t_dash = sk_tok | append: '-'
            assign t_full = sk | append: '.'
            assign iscan = 0
            for im in product.images
              if iscan >= 80
                break
              endif
              assign iscan = iscan | plus: 1
              if im.src contains t_us or im.src contains t_dot or im.src contains t_dash or im.src contains t_full
                assign card_image = im
                break
              endif
            endfor
          endif
        endif
      endif
    endif
  endif
-%}
<div class="tk-pcard">
  <a class="tk-pcard__link" href="{{ product.url }}">
    <div class="tk-pcard__media">
      {%- if card_image_url != blank -%}
        <img src="{{ card_image_url }}" class="tk-pcard__img" alt="{{ product.title | escape }}" loading="lazy">
      {%- elsif card_image != blank -%}
        {{- card_image | image_url: width: 600 | image_tag:
            loading: 'lazy', class: 'tk-pcard__img',
            alt: card_image.alt | default: product.title | escape -}}
      {%- else -%}
        <div class="tk-pcard__img tk-pcard__img--placeholder"></div>
      {%- endif -%}

      {%- comment -%} Sale badge if compare_at > price {%- endcomment -%}
      {%- if product.compare_at_price > product.price -%}
        {%- assign pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        <span class="tk-pcard__sale-badge">Save {{ pct }}%</span>
      {%- endif -%}

      <div class="tk-pcard__quick-add" data-variant-id="{{ product.first_available_variant.id }}">
        <span>Quick Add to Cart</span>
      </div>
    </div>

    <div class="tk-pcard__info">
      {%- if product.vendor != blank -%}
        <p class="tk-pcard__collection">{{ product.vendor | escape }}</p>
      {%- endif -%}
      <p class="tk-pcard__name">
        {{- product.title | escape -}}
        {%- assign size_meta = product.metafields.tk.size -%}
        {%- if size_meta != blank and size_meta != 0 and size_meta != '0' -%} &mdash; {{ size_meta }}{%- endif -%}
      </p>
      {%- if product.variants.first.sku != blank -%}
        <p class="tk-pcard__sku">SKU: {{ product.variants.first.sku }}</p>
      {%- endif -%}
      <div class="tk-pcard__bottom">
        <div class="tk-pcard__price-wrap">
          <span class="tk-pcard__price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="tk-pcard__price-was">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
        <div class="tk-pcard__finishes">
          {%- comment -%}
            Render family-finish swatches showing sister products in the same
            design family. Source priority:
              1. top_knobs.family_finishes JSON metafield (preferred — populated
                 by scripts/tag-primary-finishes.py)
              2. product.options_with_values fallback (for products that have
                 a real Finish variant axis or haven't been processed yet)
            Swatches are visual-only on the card (no nested links — the card
            itself is already a link to the PDP, where the full picker lives).
          {%- endcomment -%}
          {%- assign family_finishes = product.metafields.top_knobs.family_finishes.value -%}
          {%- if family_finishes != blank and family_finishes.size > 0 -%}
            {%- for finish in family_finishes limit: 4 -%}
              {%- render 'tk-finish-swatch', finish_name: finish.name, size: 14, extra_class: 'tk-pcard__dot' -%}
            {%- endfor -%}
            {%- if family_finishes.size > 4 -%}
              <span class="tk-pcard__more">+{{ family_finishes.size | minus: 4 }}</span>
            {%- endif -%}
          {%- else -%}
            {%- assign finish_option = blank -%}
            {%- for opt in product.options_with_values -%}
              {%- assign opt_lower = opt.name | downcase -%}
              {%- if opt_lower contains 'finish' or opt_lower contains 'color' or opt_lower contains 'colour' -%}
                {%- assign finish_option = opt -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if finish_option != blank -%}
              {%- for value in finish_option.values limit: 4 -%}
                {%- render 'tk-finish-swatch', finish_name: value, size: 14, extra_class: 'tk-pcard__dot' -%}
              {%- endfor -%}
              {%- if finish_option.values.size > 4 -%}
                <span class="tk-pcard__more">+{{ finish_option.values.size | minus: 4 }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </a>
</div>

{%- comment -%}
  Card-specific styles (only loaded when card is on the page).
  Most styles assumed to live in base.css already; this is just the new additions for sale badge + price-was.
{%- endcomment -%}
{%- unless tk_pcard_styles_loaded -%}
  {%- assign tk_pcard_styles_loaded = true -%}
  <style>
    .tk-pcard__media { position: relative; }
    .tk-pcard__sale-badge {
      position: absolute; top: 10px; left: 10px; z-index: 2;
      background: oklch(50% 0.13 145); color: #fff;
      font-family: var(--tk-font-body); font-size: 10px;
      font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 4px 8px;
    }
    .tk-pcard__price-wrap { display: flex; align-items: baseline; gap: 8px; }
    .tk-pcard__price-was {
      font-family: var(--tk-font-body); font-size: 12px;
      color: var(--color-text2); text-decoration: line-through;
    }
    .tk-pcard__more {
      font-family: var(--tk-font-body); font-size: 10px;
      color: var(--color-text2); margin-left: 4px;
    }
  </style>
{%- endunless -%}
