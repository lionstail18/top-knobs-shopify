<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>
  {%- if request.page_type == 'password' -%}
    {{- shop.name -}}
  {%- else -%}
    {{- page_title -}}
    {%- if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
    {%- comment -%}
      Append the shop name to the page title UNLESS the page title already
      establishes the brand. Many product/collection titles already begin with
      "Top Knobs" (because the underlying data follows the manufacturer's
      naming), so checking only for the full shop.name produces titles like
      "Top Knobs Pemberton Collection - Top Knobs Hardware" with redundant
      brand. Compare against the first two words of shop.name instead.
    {%- endcomment -%}
    {%- assign brand_words = shop.name | split: ' ' -%}
    {%- if brand_words.size > 1 -%}
      {%- assign brand_short = brand_words[0] | append: ' ' | append: brand_words[1] -%}
    {%- else -%}
      {%- assign brand_short = shop.name -%}
    {%- endif -%}
    {%- unless page_title contains brand_short %} &ndash; {{ shop.name }}{% endunless -%}
  {%- endif -%}
</title>

{%- if canonical_url != blank -%}
  <link rel="canonical" href="{{ canonical_url }}">
{%- endif -%}

{%- if settings.favicon != blank -%}
  {%- liquid
    assign image_type = settings.favicon | split: '?' | first | split: '.' | last | downcase
    if image_type == 'svg'
      assign image_type = 'svg+xml'
    endif
  -%}
  <link rel="icon" href="{{ settings.favicon | image_url: width: 48, height: 48 }}" type="image/{{ image_type }}">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
{%- else -%}
  {%- comment -%}
    Default Top Knobs favicon — TK monogram on navy with gold accent.
    SVG is preferred by modern browsers (sharp at any size); PNG is the
    fallback for older browsers and iOS home-screen icons. To override,
    upload a custom favicon at Theme Settings → Favicon.
  {%- endcomment -%}
  <link rel="icon" href="{{ 'favicon.svg' | asset_url }}" type="image/svg+xml">
  <link rel="alternate icon" href="{{ 'favicon.png' | asset_url }}" type="image/png">
  <link rel="apple-touch-icon" href="{{ 'favicon.png' | asset_url }}">
{%- endif -%}

{%- if page_description -%}
  <meta name="description" content="{{ page_description | escape }}">
{%- endif -%}
