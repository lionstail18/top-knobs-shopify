<section class="tk-finish-browser">
  <p class="tk-eyebrow tk-finish-browser__eyebrow">{{ section.settings.eyebrow | escape }}</p>
  <h2 class="tk-finish-browser__h2">{{ section.settings.heading | escape }}</h2>

  {%- if section.blocks.size > 0 -%}
    <div class="tk-finish-browser__swatches">
      {%- for block in section.blocks -%}
        {%- if block.type == 'finish' -%}
          <a class="tk-finish-browser__swatch" href="{{ block.settings.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            <span class="tk-finish-browser__circle" style="background: {{ block.settings.color }};"></span>
            <span class="tk-finish-browser__label">{{ block.settings.name | escape }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{%- style -%}
  .tk-finish-browser {
    padding: var(--tk-section-y) var(--tk-page-x);
    text-align: center;
    background: var(--color-bg);
  }
  .tk-finish-browser__eyebrow { margin: 0 0 10px; }
  .tk-finish-browser__h2 {
    font-family: var(--tk-font-heading);
    font-size: 40px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 48px;
    line-height: 1.1;
  }
  .tk-finish-browser__swatches {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .tk-finish-browser__swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .tk-finish-browser__swatch:hover {
    transform: translateY(-4px);
  }
  .tk-finish-browser__circle {
    display: block;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin: 0 auto 10px;
    border: 2px solid var(--color-border);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .tk-finish-browser__label {
    font-family: var(--tk-font-body);
    font-size: 12px;
    color: var(--color-text);
    line-height: 1.3;
  }
  @media (max-width: 600px) {
    .tk-finish-browser__swatches { gap: 24px; }
    .tk-finish-browser__h2 { font-size: 32px; }
    .tk-finish-browser__circle { width: 52px; height: 52px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Finish Browser",
  "tag": "div",
  "class": "tk-finish-browser-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Find Your Perfect Match"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse by Finish"
    }
  ],
  "blocks": [
    {
      "type": "finish",
      "name": "Finish Swatch",
      "settings": [
        {
          "type": "color",
          "id": "color",
          "label": "Swatch color",
          "default": "#C8C0B0"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Finish name",
          "default": "Polished Nickel"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Finish Browser" }
  ]
}
{% endschema %}
