/*
 * Top Knobs — Header Group with Mega Menu (PATCHED)
 * Replaces: sections/header-group.json
 *
 * WHAT THIS DOES:
 * Adds 4 mega menu blocks to the header section: "Knobs", "Pulls",
 * "Bath & Cabinet Hardware", and "By Finish". Each block matches a
 * top-level menu item by title (Canopy mega-menu convention) and renders
 * its child links as a multi-column grid with collection images.
 *
 * REQUIRED IN SHOPIFY ADMIN → NAVIGATION:
 * Your "main-menu" navigation menu must have top-level items with these
 * exact titles (case-insensitive):
 *   • Knobs
 *   • Pulls
 *   • Bath & Cabinet Hardware  (or just "Bath" or "Cabinet Hardware")
 *   • By Finish                (or "Finishes")
 * Each must have child links (collections). The mega menu auto-renders
 * those children as columns. If a top-level item is missing children,
 * it just won't show a flyout.
 *
 * AFTER COMMITTING THIS FILE:
 * Shopify auto-syncs to the live theme. Hard-refresh the storefront
 * (Cmd+Shift+R). Hover any of the 4 menu items to see the mega menu.
 *
 * CUSTOMIZING IN ADMIN:
 * Customize → Header section → block list. You'll see the 4 blocks. You
 * can add promo images, edit the title-match, toggle collection images
 * on/off, change badges, etc. — all without touching code.
 */
{
  "type": "header",
  "name": "Header Group",
  "sections": {
    "announcement-bar": {
      "type": "announcement-bar",
      "blocks": {
        "msg-1": { "type": "message", "settings": { "text": "✦ Authorized Top Knobs Dealer" } },
        "msg-2": { "type": "message", "settings": { "text": "✦ Free Shipping on Orders $99+" } },
        "msg-3": { "type": "message", "settings": { "text": "✦ Lowest Prices Online — Guaranteed" } }
      },
      "block_order": ["msg-1", "msg-2", "msg-3"],
      "settings": { "bg_color": "#0d1526", "text_color": "#f6f7fa", "rotate_delay": 5 }
    },
    "announcement": {
      "type": "announcement",
      "blocks": {},
      "block_order": [],
      "disabled": true,
      "settings": {
        "announcement_homepage_only": false,
        "enable_country_selector": true,
        "enable_language_selector": true,
        "bg_color": "#1a237e",
        "text_color": "#ffffff",
        "text_type_scale": "small",
        "read_time": 7
      }
    },
    "header": {
      "type": "header",
      "blocks": {
        "mega-knobs": {
          "type": "columns",
          "settings": {
            "title": "Knobs",
            "collection_images": "standard",
            "collection_use_product_image": true,
            "show_underline": false,
            "promo_position": "right"
          }
        },
        "mega-pulls": {
          "type": "columns",
          "settings": {
            "title": "Pulls",
            "collection_images": "standard",
            "collection_use_product_image": true,
            "show_underline": false,
            "promo_position": "right"
          }
        },
        "mega-bath": {
          "type": "columns",
          "settings": {
            "title": "Bath & Cabinet Hardware, Bath, Cabinet Hardware, Bath Hardware",
            "collection_images": "standard",
            "collection_use_product_image": true,
            "show_underline": false,
            "promo_position": "bottom"
          }
        },
        "mega-finish": {
          "type": "columns",
          "settings": {
            "title": "By Finish, Finishes, Finish",
            "collection_images": "standard",
            "collection_use_product_image": false,
            "show_underline": false,
            "promo_position": "bottom"
          }
        }
      },
      "block_order": ["mega-knobs", "mega-pulls", "mega-bath", "mega-finish"],
      "settings": {
        "mobile_menu_position": "burger-left",
        "enable_sticky": true,
        "hide_menu": false,
        "logo_text": "",
        "logo_text_font": "nunito_sans_n7",
        "logo_type_scale": "2",
        "logo_width": 150,
        "logo_h1": true,
        "logo_position": "top-left",
        "enable_search": true,
        "minimise_search_mobile": false,
        "minimise_search_desktop": false,
        "menu": "main-menu",
        "menu_center": true,
        "link_toggle": "mobile",
        "repeat_links": true,
        "menu_featured_link": "Sale",
        "enable_customer_account_component": false,
        "customer_account_menu": "customer-account-main-menu",
        "cta_show": false,
        "cta_icon": "phone",
        "cta_label": "Call us",
        "cta_link": "",
        "cta_border_color": "#ebebeb",
        "cta_bg_color": "#ebebeb",
        "cta_text_color": "#222222",
        "bg_color": "#f6f7fa",
        "text_color": "#0d1526",
        "accent_color": "#c2a058",
        "desktop_menu_bg_color": "#f6f7fa",
        "desktop_menu_text_color": "#0d1526",
        "mobile_menu_bg_color": "#f6f7fa",
        "mobile_menu_text_color": "#0d1526"
      }
    }
  },
  "order": ["announcement-bar", "announcement", "header"]
}
