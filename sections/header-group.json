/*
 * Top Knobs — Header Group with Mega Menu (PATCHED v2)
 * Replaces: sections/header-group.json
 *
 * STRUCTURE (matches prototype):
 *   • Products  →  shape-based subcategories (5 columns: Knobs, Pulls, Appliance, Bath, Backplates)
 *   • Collections  →  all named Top Knobs collections (multi-column grid)
 *   • Finishes  →  finish swatches with colored dots
 *
 * REQUIRES IN SHOPIFY ADMIN → NAVIGATION:
 * Your "main-menu" must have top-level items titled exactly:
 *   "Products"   (with Knobs / Pulls / Appliance Pulls / Bath Accessories / Backplates as children, each with shape children)
 *   "Collections" (with collection links as direct children)
 *   "Finishes"   (with finish links as direct children)
 * Use the SIDEKICK-PROMPT.md to set this up automatically.
 *
 * AFTER COMMITTING:
 * Shopify auto-syncs. Hard-refresh the storefront. Hover each item to see the mega menu.
 */
{
  "type": "header",
  "name": "Header Group",
  "sections": {
    "announcement-bar": {
      "type": "announcement-bar",
      "blocks": {
        "msg-1": { "type": "message", "settings": { "text": "✦ Authorized Top Knobs Dealer" } },
        "msg-2": { "type": "message", "settings": { "text": "✦ Free Shipping on Orders $99+" } },
        "msg-3": { "type": "message", "settings": { "text": "✦ Lowest Prices Online — Guaranteed" } }
      },
      "block_order": ["msg-1", "msg-2", "msg-3"],
      "settings": { "bg_color": "#0d1526", "text_color": "#f6f7fa", "rotate_delay": 5 }
    },
    "announcement": {
      "type": "announcement",
      "blocks": {},
      "block_order": [],
      "disabled": true,
      "settings": {
        "announcement_homepage_only": false,
        "enable_country_selector": true,
        "enable_language_selector": true,
        "bg_color": "#1a237e",
        "text_color": "#ffffff",
        "text_type_scale": "small",
        "read_time": 7
      }
    },
    "header": {
      "type": "header",
      "blocks": {
        "mega-products": {
          "type": "columns",
          "settings": {
            "title": "Products",
            "collection_images": "none",
            "collection_use_product_image": false,
            "show_underline": true,
            "promo_position": "right"
          }
        },
        "mega-collections": {
          "type": "columns",
          "settings": {
            "title": "Collections",
            "collection_images": "none",
            "collection_use_product_image": false,
            "show_underline": false,
            "promo_position": "right"
          }
        },
        "mega-finish": {
          "type": "columns",
          "settings": {
            "title": "Finishes",
            "collection_images": "swatch",
            "collection_use_product_image": false,
            "show_underline": false,
            "promo_position": "bottom"
          }
        }
      },
      "block_order": ["mega-products", "mega-collections", "mega-finish"],
      "settings": {
        "mobile_menu_position": "burger-left",
        "enable_sticky": true,
        "hide_menu": false,
        "logo_text": "",
        "logo_text_font": "nunito_sans_n7",
        "logo_type_scale": "2",
        "logo_width": 150,
        "logo_h1": true,
        "logo_position": "top-left",
        "enable_search": true,
        "minimise_search_mobile": false,
        "minimise_search_desktop": false,
        "menu": "main-menu",
        "menu_center": true,
        "link_toggle": "mobile",
        "repeat_links": true,
        "menu_featured_link": "What's New",
        "enable_customer_account_component": false,
        "customer_account_menu": "customer-account-main-menu",
        "cta_show": false,
        "cta_icon": "phone",
        "cta_label": "Call us",
        "cta_link": "",
        "cta_border_color": "#ebebeb",
        "cta_bg_color": "#ebebeb",
        "cta_text_color": "#222222",
        "bg_color": "#f6f7fa",
        "text_color": "#0d1526",
        "accent_color": "#c2a058",
        "desktop_menu_bg_color": "#f6f7fa",
        "desktop_menu_text_color": "#0d1526",
        "mobile_menu_bg_color": "#f6f7fa",
        "mobile_menu_text_color": "#0d1526"
      }
    }
  },
  "order": ["announcement-bar", "announcement", "header"]
}
