<div class="tk-feat-col">
  <div class="tk-feat-col__header">
    <div>
      <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tk-feat-col__h2">{{ section.settings.heading | escape }}</h2>
    </div>
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url | default: routes.collections_url }}"
         class="tk-btn tk-btn--ghost-border tk-feat-col__view-all">
        {{- section.settings.btn_label | escape -}}
      </a>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="tk-feat-col__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <a class="tk-feat-col__card" href="{{ block.settings.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            <div class="tk-feat-col__img-wrap">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image | image_url: width: 800 | image_tag:
                    loading: 'lazy',
                    class: 'tk-feat-col__img',
                    alt: block.settings.title | escape -}}
              {%- else -%}
                <div class="tk-feat-col__img tk-feat-col__img--placeholder"></div>
              {%- endif -%}
              {%- if block.settings.badge != blank -%}
                <span class="tk-feat-col__badge">{{ block.settings.badge | escape }}</span>
              {%- endif -%}
            </div>
            <div class="tk-feat-col__body">
              <p class="tk-feat-col__name">{{ block.settings.title | escape }}</p>
              {%- if block.settings.description != blank -%}
                <p class="tk-feat-col__desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
              <p class="tk-feat-col__cta">Shop Collection &rarr;</p>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{%- style -%}
  .tk-feat-col {
    background: var(--color-bg2);
    padding-bottom: 80px;
  }
  .tk-feat-col__header {
    padding: 56px var(--tk-page-x) 40px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
  }
  .tk-feat-col__header .tk-eyebrow { margin: 0 0 10px; }
  .tk-feat-col__h2 {
    font-family: var(--tk-font-heading);
    font-size: 40px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    line-height: 1.1;
  }
  .tk-feat-col__view-all {
    flex-shrink: 0;
    padding: 10px 24px;
    font-size: 11px;
    letter-spacing: 0.1em;
  }
  .tk-feat-col__grid {
    padding: 0 var(--tk-page-x);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .tk-feat-col__card {
    display: block;
    text-decoration: none;
    background: var(--color-bg);
    transition: box-shadow 0.2s ease;
  }
  .tk-feat-col__card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
  }
  .tk-feat-col__img-wrap {
    position: relative;
    overflow: hidden;
  }
  .tk-feat-col__img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .tk-feat-col__img--placeholder {
    height: 220px;
    background: var(--color-border);
  }
  .tk-feat-col__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--tk-font-body);
    font-size: 9px;
    letter-spacing: 0.15em;
    padding: 4px 10px;
    text-transform: uppercase;
  }
  .tk-feat-col__body {
    padding: 18px 20px 22px;
  }
  .tk-feat-col__name {
    font-family: var(--tk-font-heading);
    font-size: 22px;
    color: var(--color-text);
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .tk-feat-col__desc {
    font-family: var(--tk-font-body);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-text2);
    margin: 0 0 14px;
  }
  .tk-feat-col__cta {
    font-family: var(--tk-font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0;
  }
  @media (max-width: 900px) {
    .tk-feat-col__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .tk-feat-col__grid { grid-template-columns: 1fr; }
    .tk-feat-col__header { flex-direction: column; align-items: flex-start; }
    .tk-feat-col__h2 { font-size: 32px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Featured Collections",
  "tag": "div",
  "class": "tk-feat-col-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Curated for You"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "View All 40+ Collections"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Collection image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Collection name",
          "default": "The Pemberton Collection"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Modern elegance meets timeless form. Clean architectural lines in premium finishes."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label (e.g. NEW, BESTSELLER)"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Featured Collections" }
  ]
}
{% endschema %}
