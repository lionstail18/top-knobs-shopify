{% # theme-check-disable LiquidTag, TemplateLength %}

{%- if section.settings.logo == blank and section.settings.logo_text_font.system? == false -%}
  <link rel="preload" href="{{ section.settings.logo_text_font | font_url }}" as="font" type="font/woff2" crossorigin fetchpriority="high">
  {%- style -%}
    {{- section.settings.logo_text_font | font_face: font_display: 'swap' -}}
  {%- endstyle -%}
{%- endif -%}

{%- liquid
  assign has_mega_nav_columns = false
  assign has_mega_nav_sidebar = false

  if section.blocks.size > 0
    for block in section.blocks
      if block.type == "columns"
        assign has_mega_nav_columns = true
      elsif block.type == "sidebar"
        assign has_mega_nav_sidebar = true
      endif
    endfor
  endif

  assign search_is_minimised = false
  if section.settings.minimise_search_mobile or section.settings.minimise_search_desktop
    assign search_is_minimised = true
  endif

  assign show_search_types = false
  if settings.show_search_types and shop.types
    assign show_search_types = true
  endif

  assign center_logo = false
  if section.settings.logo_position == "top-center"
    assign center_logo = true
  endif
-%}

{%- style -%}
  .header {
  --bg-color: {{ section.settings.bg_color.rgba }};
  --text-color: {{ section.settings.text_color.rgb }};
  --icon-color: {{ section.settings.text_color.rgb }};
  --mobile-menu-bg-color: {{ section.settings.mobile_menu_bg_color.rgba }};
  --mobile-menu-text-color: {{ section.settings.mobile_menu_text_color.rgb }};
  --desktop-menu-bg-color: {{ section.settings.desktop_menu_bg_color.rgba }};
  --desktop-menu-text-color: {{ section.settings.desktop_menu_text_color.rgb }};
  --nav-bg-color: {{ section.settings.bg_color.rgb }};
  --nav-text-color: {{ section.settings.text_color.rgb }};
  --nav-child-bg-color:  {{ section.settings.bg_color.rgb }};
  --nav-child-text-color: {{ section.settings.text_color.rgb }};
  --header-accent-color: {{ section.settings.accent_color.rgb }};
  --search-bg-color: {{ settings.bg_color.rgb }};
  --search-text-color: {{ settings.text_color.rgb }};
  {% unless section.settings.logo %}
    --logo_type_scale: var(--body-font-size) * {{ section.settings.logo_type_scale }};
    --logo_font-size: calc((var(--logo_type_scale) / 1.5) * var(--fluid-1-5));
    --logo_text-font: {{ section.settings.logo_text_font.family }};
  {% endunless %}
  {% if settings.cart_shaking and cart != empty %}
    --shake-delay: 4s;
  {% endif %}
  }
{%- endstyle -%}

{%- style -%}
  /* ── Top Knobs wordmark ────────────────────────────────────── */
  .tk-wordmark {
    display: inline-block;
    text-decoration: none;
    color: inherit;
    line-height: 1;
  }
  .tk-wordmark__row1 {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 6px;
  }
  .tk-wordmark__brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgb(var(--text-color));
    line-height: 1;
  }
  .tk-wordmark__outlet {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgb(var(--header-accent-color));
    text-transform: uppercase;
  }
  .tk-wordmark__sub {
    display: block;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgb(var(--text-color));
    opacity: 0.6;
    text-transform: uppercase;
    text-align: right;
    margin-top: 3px;
  }

  /* ── Header row: 72 px tall, 48 px side gutter ─────────────── */
  @media (min-width: 769px) {
    .cc-header .header {
      padding-top: 0;
    }
    .cc-header .header__grid.container {
      padding-inline-start: 48px;
      padding-inline-end: 48px;
    }
    .cc-header .header__logo,
    .cc-header .header__icons {
      height: 72px;
      margin-bottom: 0;
      display: flex;
      align-items: center;
      padding-inline-start: 0;
    }
    .cc-header .header__logo {
      flex: 0 0 auto;
      padding-inline-end: clamp(24px, 3vw, 40px);
    }
    .cc-header .header__logo .logo__link {
      display: flex;
      align-items: center;
      min-height: 72px;
    }
    .cc-header .header__logo .tk-wordmark {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .cc-header .header__search {
      max-width: 520px;
      margin-inline-start: auto;
      margin-inline-end: auto;
      transform: translateY(4px);
    }
  }

  /* ── Search: 40 px height, Jost, no radius ─────────────────── */
  .cc-header .search__form {
    height: 40px;
    border-radius: 0;
  }
  .cc-header .search__input {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
  }

  /* ── Cart badge: gold ───────────────────────────────────────── */
  .cc-header .header__cart-count {
    background-color: rgb(var(--header-accent-color));
    color: #fff;
    box-shadow: 0 0 0 2px rgba(var(--bg-color));
  }

  /* ── Icons: smaller SVG + visible Jost labels ───────────────── */
  @media (min-width: 1024px) {
    .cc-header .header__icons .header__icon svg {
      width: 18px;
      height: 18px;
    }
    .cc-header .header__icons .header__icon .icon--cart {
      width: 18px;
      height: 18px;
    }
  }
  .cc-header .header__icons .header__icon .visually-hidden {
    position: static;
    width: auto;
    height: auto;
    overflow: visible;
    clip: auto;
    -webkit-clip-path: none;
    clip-path: none;
    white-space: normal;
    margin: 0;
    font-family: 'Jost', sans-serif;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-align: center;
    margin-top: 2px;
    opacity: 0.6;
    color: rgb(var(--text-color));
  }

  /* ── Nav bar: 44 px, Jost 12 px uppercase, gold hover ──────── */
  @media (min-width: 769px) {
    .cc-header .main-nav,
    .cc-header .main-nav .secondary-nav {
      justify-content: center;
      align-items: stretch;
      margin: 0;
    }
    .cc-header .main-nav__row {
      margin: 0;
      height: 44px;
      align-items: stretch;
    }
    .cc-header a.main-nav__item--primary {
      font-family: 'Jost', sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0 20px;
      height: 44px;
      display: flex;
      align-items: center;
    }
    /* Gold underline on hover / active — uses currentColor trick */
    .cc-header .main-nav__row:hover,
    .cc-header .main-nav__row.is-active,
    .cc-header .main-nav__item--dropdown.is-open > .main-nav__row {
      color: rgb(var(--header-accent-color));
    }
    /* Mega menu top rule in gold */
    .cc-header .main-nav__child.mega-nav {
      border-top-color: rgb(var(--header-accent-color));
    }
  }

  /* ── Collections mega-menu: serif list, gold overline, hairline dividers ── */
  @media (min-width: 769px) {
    .cc-header .mega-nav--collections > .container {
      padding-top: 32px;
      padding-bottom: 40px;
    }
    /* "BROWSE COLLECTIONS" overline label */
    .cc-header .mega-nav--collections > .container::before {
      content: "Browse Collections";
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(var(--header-accent-color));
      margin-bottom: 20px;
    }
    /* Column-major flow: alphabetical reads top-to-bottom, then left-to-right.
       Override the parent's grid layout with CSS multi-column. row-gap: 0
       neutralises the grid row gap that was previously stretching the rows. */
    .cc-header .mega-nav--collections .child-nav {
      display: block;
      column-count: 4;
      column-gap: 40px;
      row-gap: 0;
    }
    .cc-header .mega-nav--collections .child-nav > li {
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
    }
    /* Serif collection names with hairline divider under each */
    .cc-header .mega-nav--collections .child-nav__item {
      display: block;
      width: 100%;
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 400;
      letter-spacing: 0;
      text-transform: none;
      line-height: 1.4;
      padding-top: 10px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(var(--text-color), 0.15);
    }
    .cc-header .mega-nav--collections .child-nav__item:hover {
      color: rgb(var(--header-accent-color));
    }
    /* Belt-and-suspenders: hide thumbnails in the Collections panel even if
       the JSON setting drifts back to "standard" or stale data slips through. */
    .cc-header .mega-nav--collections .main-nav__collection-image,
    .cc-header .mega-nav--collections .child-nav__item-collection-image {
      display: none !important;
    }
  }

  /* ── Finishes mega-menu: swatch grid with gold overline ──────── */
  @media (min-width: 769px) {
    .cc-header .mega-nav--finishes > .container {
      padding-top: 32px;
      padding-bottom: 40px;
    }
    /* "BROWSE BY FINISH" overline label */
    .cc-header .mega-nav--finishes > .container::before {
      content: "Browse by Finish";
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(var(--header-accent-color));
      margin-bottom: 28px;
    }
    /* Reset parent grid layout — finishes panel uses a wrap-grid of swatches,
       not the column flow used by Products / Collections. */
    .cc-header .mega-nav--finishes .child-nav {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      column-gap: 16px;
      row-gap: 18px;
    }
    /* Each finish: swatch on top, label below, both centred. */
    .cc-header .mega-nav--finishes .child-nav__item--swatch {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 0;
      text-align: center;
      text-decoration: none;
      color: rgb(var(--text-color));
      border: none;
      transition: transform 0.15s ease;
    }
    .cc-header .mega-nav--finishes .child-nav__item--swatch:hover {
      transform: translateY(-2px);
    }
    .cc-header .mega-nav--finishes .child-nav__item-swatch-label {
      font-family: 'Jost', sans-serif;
      font-size: 13px;
      font-weight: 400;
      line-height: 1.3;
      transition: color 0.2s ease;
    }
    .cc-header .mega-nav--finishes .child-nav__item--swatch:hover .child-nav__item-swatch-label {
      color: rgb(var(--header-accent-color));
    }
  }

  /* ── Products mega-menu: gold uppercase category headers, clean sub-lists ── */
  @media (min-width: 769px) {
    .cc-header .mega-nav--products > .container {
      padding-top: 32px;
      padding-bottom: 40px;
    }
    /* "BROWSE BY PRODUCT TYPE" overline label */
    .cc-header .mega-nav--products > .container::before {
      content: "Browse by Product Type";
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(var(--header-accent-color));
      margin-bottom: 28px;
    }
    /* Reset parent layout and use a responsive grid: 5 columns at full width,
       collapses gracefully if there are fewer categories or narrower viewport. */
    .cc-header .mega-nav--products .child-nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      column-gap: 40px;
      row-gap: 0;
      align-items: start;
    }
    .cc-header .mega-nav--products .child-nav > li {
      min-width: 0;
    }
    /* Category header (Knobs, Pulls, Appliance Pulls...) — gold uppercase + hairline */
    .cc-header .mega-nav--products .child-nav__item {
      display: block;
      width: 100%;
      font-family: 'Jost', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(var(--header-accent-color));
      padding: 0 0 10px 0;
      margin-bottom: 14px;
      border-bottom: 1px solid rgba(var(--text-color), 0.18);
      line-height: 1.3;
    }
    .cc-header .mega-nav--products .child-nav__item:hover {
      opacity: 0.75;
    }
    /* Sub-items list (Round Knobs, Bar Pulls, etc.) */
    .cc-header .mega-nav--products .main-nav__grandchild {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0;
      margin: 0;
    }
    .cc-header .mega-nav--products .grandchild-nav__item {
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 14px;
      font-weight: 400;
      letter-spacing: 0;
      text-transform: none;
      color: rgb(var(--text-color));
      padding: 7px 0;
      line-height: 1.4;
      transition: color 0.15s ease;
    }
    .cc-header .mega-nav--products .grandchild-nav__item:hover {
      color: rgb(var(--header-accent-color));
    }
    /* Hide the mobile-accordion chevrons on desktop */
    .cc-header .mega-nav--products .main-nav__toggle-btn {
      display: none;
    }
    /* Hide any inherited grandchild thumbnails — Products menu is text-only */
    .cc-header .mega-nav--products .grandchild-nav__image,
    .cc-header .mega-nav--products .main-nav__collection-image,
    .cc-header .mega-nav--products .child-nav__item-collection-image {
      display: none !important;
    }
  }
{%- endstyle -%}

<store-header class="header bg-theme-bg text-theme-text{% if section.settings.enable_sticky or search_is_minimised %} has-motion{% endif %}{% if search_is_minimised %} search-is-collapsed{% endif %}"
  {%- if section.settings.enable_sticky -%} data-is-sticky="true" data-hide-menu="{{ section.settings.hide_menu }}"{%- endif -%}
  {%- if search_is_minimised -%} data-is-search-minimised="true"{%- endif -%}
  style="--header-transition-speed: 300ms">

  {%- capture logo -%}
    <div class="header__logo header__logo--{{ section.settings.logo_position }} logo{% if center_logo %} text-center{% endif %} flex js-closes-menu">
      {%- if request.page_type == 'index' and section.settings.logo_h1 -%}
        <h1 class="logo__h1 m-0">
      {%- endif -%}
        <a class="logo__link inline-block" href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            {%- liquid
              assign logo_width = section.settings.logo_width
              if section.settings.logo.width < logo_width
                assign logo_width = section.settings.logo.width
              endif
              assign logo_width_double = logo_width | times: 2
              assign alt_text = section.settings.logo.alt | default: shop.name
            -%}
            <span class="flex" style="max-width: {{ section.settings.logo_width | plus: 0 }}px;">
              <picture>
                {%- if section.settings.logo_mobile -%}
                <source media="(max-width: 768px)" srcset="{{ section.settings.logo_mobile | image_url: width: logo_width_double }}" alt="{{ alt_text }}" loading="eager">
                {%- endif -%}
                {{ section.settings.logo | image_url: width: logo_width_double | image_tag: alt: alt_text, loading: "eager" }}
              </picture>
            </span>
          {%- else -%}
            <span class="tk-wordmark" aria-label="{{ shop.name | escape }}">
              <span class="tk-wordmark__row1" aria-hidden="true">
                <span class="tk-wordmark__brand">TOP KNOBS</span>
                <span class="tk-wordmark__outlet">HARDWARE OUTLET</span>
              </span>
              <span class="tk-wordmark__sub" aria-hidden="true">AUTHORIZED DEALER · LOWEST PRICES ONLINE</span>
            </span>
          {%- endif -%}
        </a>
      {%- if request.page_type == 'index' and section.settings.logo_h1 -%}
        </h1>
      {%- endif -%}
    </div>
  {%- endcapture -%}

  <header class="header__grid{% if center_logo %} header__grid--centered-logo{% else %} header__grid--left-logo{% endif %} container flex flex-wrap items-center">
    {{ logo }}
    {%- if section.settings.enable_search -%}
      {%- if settings.enable_predictive_search -%}
        <link rel="stylesheet" href="{{ 'predictive-search.css' | asset_url }}"{% unless show_search_types %} media="print" onload="this.media='all'"{% endunless %}>
        <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
        <script src="{{ 'tabs.js' | asset_url }}" defer="defer"></script>
      {%- endif -%}

      <div class="header__search{% if section.settings.minimise_search_mobile %} header__search--collapsible-mob{% endif %}{% if section.settings.minimise_search_desktop %} header__search--collapsible-desktop{% endif %}{% if search_is_minimised %} js-search-bar{% endif %} relative js-closes-menu"{% if search_is_minimised %} id="search-bar"{% endif %}>
        {%- if center_logo and section.settings.minimise_search_desktop -%}
          <a class="header__icon header__icon--search-left absolute hidden md:block js-show-search-left" href="{{ routes.search_url }}" aria-controls="search-bar">
            <span class="header__icon--search-left-search">
              {% render 'icon-search' %}
            </span>
            <span class="header__icon--search-left-close">
              {% render 'icon-close' %}
            </span>
            <span class="visually-hidden">{{ 'general.icon_labels.search' | t }}</span>
          </a>
        {%- endif -%}

        {% render 'predictive-search', id: 'header-search', show_search_types: show_search_types %}
      </div>
    {%- elsif center_logo -%}
      <div class="header__search"></div>
    {%- endif -%}

    <div class="header__icons flex justify-end mis-auto js-closes-menu">
      {%- if section.settings.enable_search and search_is_minimised -%}
        {%- unless center_logo and section.settings.minimise_search_mobile == false and section.settings.minimise_search_desktop -%}
          {%- liquid
            if center_logo and section.settings.minimise_search_mobile
              assign search_button_class = "md:hidden"
            elsif section.settings.minimise_search_mobile and section.settings.minimise_search_desktop == false
              assign search_button_class = "md:hidden"
            elsif section.settings.minimise_search_mobile == false and section.settings.minimise_search_desktop
              assign search_button_class = "hidden md:block"
            endif
          -%}
          <a class="header__icon {{ search_button_class }} js-show-search" href="{{ routes.search_url }}" aria-controls="search-bar">
            {% render 'icon-search' %}
            <span class="visually-hidden">{{ 'general.icon_labels.search' | t }}</span>
          </a>
        {%- endunless -%}
      {%- endif -%}
      {%- if shop.customer_accounts_enabled -%}
        {%- if section.settings.enable_customer_account_component -%}
          <shopify-account menu="{{ section.settings.customer_account_menu }}">
            {%- if customer -%}
              <div class="account-button__fallback"></div>
            {%- else -%}
              <div slot="signed-out-avatar">
                <span class="header__icon">
                  {% render 'icon-customer' %}
                  <span class="visually-hidden">{{ 'sections.header.account' | t }}</span>
                </span>
              </div>
            {%- endif -%}
          </shopify-account>
        {%- else -%}
          {%- if customer -%}
            <a class="header__icon" href="{{ routes.account_url }}">
              {% render 'icon-customer' %}
              <span class="visually-hidden">{{ 'sections.header.account' | t }}</span>
            </a>
          {%- else -%}
            <a class="header__icon" href="{{ routes.account_login_url }}">
              {% render 'icon-customer' %}
              <span class="visually-hidden">{{ 'sections.header.log_in' | t }}</span>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      <a class="header__icon{% if settings.cart_shaking and cart != empty %} header__icon--cart-shake has-motion{% endif %} relative" id="cart-icon" href="{{ routes.cart_url }}"{% if settings.cart_shaking and cart != empty %} data-shake-frequency="{{ settings.cart_shaking_frequency }}"{% endif %}{% if settings.preload_links %} data-no-instant{% endif %}>
        {%- if settings.cart_icon == 'bag' -%}
          {%- render 'icon-bag' -%}
          <span class="visually-hidden">{{ 'sections.header.bag' | t }}</span>
        {%- elsif settings.cart_icon == 'basket' -%}
          {%- render 'icon-basket' -%}
          <span class="visually-hidden">{{ 'sections.header.basket' | t }}</span>
        {%- else -%}
          {%- render 'icon-cart' -%}
          <span class="visually-hidden">{{ 'sections.header.cart' | t }}</span>
        {%- endif -%}

        <div id="cart-icon-bubble">
          {%- if cart != empty -%}
            <div class="header__cart-count absolute bg-theme-text text-theme-bg text-center">
              {%- if cart.item_count < 10000 -%}
                <span aria-hidden="true" class="header__cart-count-number">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          {%- endif -%}
        </div>
      </a>
    </div>

    {%- if section.settings.menu != blank -%}
      {%- assign total_promo_count = 0 -%}
      {%- assign featured_links = section.settings.menu_featured_link | downcase | replace: ', ', ',' | replace: ' ,', ',' | split: ',' -%}
      <main-menu class="main-menu{% if section.settings.mobile_menu_position == "burger-left" %} main-menu--left-mob{% endif %}" data-menu-sensitivity="200"{% if section.settings.link_toggle != "disabled" %} data-link-toggle="{{ section.settings.link_toggle }}"{% endif %}>
        <button type="button" class="main-menu__toggle md:hidden" aria-expanded="false" aria-controls="main-menu-content" aria-label="{{ 'general.icon_labels.menu' | t | escape }}">
          <span class="main-menu__toggle-icon" aria-hidden="true"></span>
          <span class="visually-hidden">{{ 'general.icon_labels.menu' | t }}</span>
        </button>
        <div class="main-menu__content{% if section.settings.logo_position == "bottom-left" %} main-menu__content--logo{% if section.settings.cta_show == false %} main-menu__content--logo-only{% endif %}{% endif %} has-motion {% if section.settings.cta_show == false and section.settings.menu_center %}justify-center{% else %}justify-between{% endif %}" id="main-menu-content">
          {%- if section.settings.logo_position == "bottom-left" -%}
            {{ logo | replace: "<h1", "<h2" | replace: "</h1", "</h2" }}
          {%- endif -%}
          <nav aria-label="{{ 'accessibility.main_navigation' | t }}">
            <ul class="main-nav{% if section.settings.cta_show == false and section.settings.menu_center %} justify-center{% endif %}">
              {%- for link in section.settings.menu.links -%}
                {%- assign link_title_downcase = link.title | downcase -%}
                {%- if link.links != blank -%}
                  {%- liquid
                    assign mega_nav = false
                    assign link_title_downcase = link.title | strip | downcase
                    for block in section.blocks
                      assign mega_name_titles = block.settings.title | downcase | replace: ', ', ',' | replace: ' ,', ',' | split: ','
                      if mega_name_titles contains link_title_downcase
                        assign mega_nav = block
                        break
                      endif
                    endfor
                  -%}
                {%- endif -%}

                <li{% if link.links != blank %} class="main-nav__item--dropdown{% if mega_nav %} js-mega-nav{% endif %}"{% if mega_nav %} {{ mega_nav.shopify_attributes }}{% endif %}{% endif %}>
                  <div class="main-nav__row{% if link.links == blank %} main-nav__row--leaf{% else %} js-nav-hover{% endif %}{% if link.current %} is-active{% endif %}{% if featured_links contains link_title_downcase %} main-nav__link--featured{% endif %}">
                    <a class="main-nav__item--primary{% if link.current %} is-active{% endif %}" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
                      {{- link.title | escape -}}
                    </a>
                    {%- if link.links != blank -%}
                      <button type="button" class="main-nav__toggle-btn js-toggle" aria-expanded="false" aria-controls="nav-dropdown-{{ forloop.index }}" aria-label="{{ 'accessibility.toggle_submenu' | t: title: link.title | escape }}">
                        {%- render 'icon-chevron-down' -%}
                      </button>
                    {%- endif -%}
                  </div>
                  {%- if link.links != blank -%}
                    {%- liquid
                      assign child_nav_classes = ""
                      assign grandchild_nav_classes = ""
                      assign flex_auto = false
                      assign has_badges = false
                      assign mega_nav_has_columns = false

                      if mega_nav.type == "columns" or mega_nav.type == "sidebar"
                        assign mega_nav_has_columns = true
                      endif

                      if mega_nav == false
                        assign child_nav_classes = "child-nav--dropdown"
                      else
                        assign has_grandchildren_menus = false
                        for child_link in link.links
                          if child_link.links != blank
                            assign has_grandchildren_menus = true
                            break
                          endif
                        endfor

                        assign promo_count = 0
                        if mega_nav.settings.promo1_content != blank or mega_nav.settings.promo1_image != blank
                          assign promo_count = promo_count | plus: 1
                        endif
                        if mega_nav.settings.promo2_content != blank or mega_nav.settings.promo2_image != blank
                          assign promo_count = promo_count | plus: 1
                        endif
                        if mega_nav.settings.promo3_content != blank or mega_nav.settings.promo3_image != blank
                          assign promo_count = promo_count | plus: 1
                        endif
                        assign total_promo_count = total_promo_count | plus: promo_count

                        assign badge_colors = ""
                        if mega_nav_has_columns
                          if mega_nav.settings.badge1_link != blank and mega_nav.settings.badge1_text != blank
                            assign has_badges = true
                            assign badge1 = mega_nav.settings.badge1_link | downcase | replace: ', ', ',' | replace: ' ,', ',' | split: ','
                            assign badge_colors = "--badge-1-color:" | append: mega_nav.settings.badge1_color.rgb | append: ";"
                          endif

                          if mega_nav.settings.badge2_link != blank and mega_nav.settings.badge2_text != blank
                            assign has_badges = true
                            assign badge2 = mega_nav.settings.badge2_link | downcase | replace: ', ', ',' | replace: ' ,', ',' | split: ','
                            assign badge_colors = badge_colors | append: "--badge-2-color:" | append: mega_nav.settings.badge2_color.rgb | append: ";"
                          endif

                          if mega_nav.settings.badge3_link != blank and mega_nav.settings.badge3_text != blank
                            assign has_badges = true
                            assign badge3 = mega_nav.settings.badge3_link | downcase | replace: ', ', ',' | replace: ' ,', ',' | split: ','
                            assign badge_colors = badge_colors | append: "--badge-3-color:" | append: mega_nav.settings.badge3_color.rgb | append: ";"
                          endif
                        endif

                        assign num_columns = link.links | size
                        if mega_nav.type == "columns"
                          if num_columns < 4 and promo_count > 0
                            assign child_nav_classes = "md:flex md:nav-gap-x-16"
                            assign flex_auto = true
                          else
                            assign child_nav_classes = "md:grid md:nav-gap-x-16 md:nav-gap-y-4 md:grid-cols-3"
                            if mega_nav.settings.promo_position == "bottom" or promo_count == 0
                              assign child_nav_classes = child_nav_classes | append: " lg:grid-cols-4"
                            else
                              assign child_nav_classes = child_nav_classes | append: " self-start xl:grid-cols-4"
                            endif
                          endif
                        elsif mega_nav.type == "sidebar"
                          assign grandchild_nav_classes = "md:grid md:nav-gap-x-8 md:nav-gap-y-4"
                          if settings.dock_cart_drawer and settings.cart_type == 'drawer'
                            assign grandchild_nav_classes = grandchild_nav_classes | append: " md:grid-cols-3 xxl:grid-cols-4"
                          else
                            assign grandchild_nav_classes = grandchild_nav_classes | append: " md:nav-grid-cols-4"
                          endif
                        endif
                      endif
                    -%}
                    <div class="main-nav__child{% if mega_nav %} mega-nav mega-nav--{{ mega_nav.type }} mega-nav--{{ mega_nav.settings.title | split: ',' | first | strip | handleize }}{% if has_grandchildren_menus == false %} mega-nav--no-grandchildren{% endif %}{% endif %} has-motion" id="nav-dropdown-{{ forloop.index }}">
                      {% if mega_nav %}<div class="container{% if promo_count > 0 %} mega-nav--promos-{{ mega_nav.settings.promo_position }}{% endif %}">{% endif %}
                        <ul class="child-nav{% if child_nav_classes %} {{ child_nav_classes }}{% endif %}">
                          <li class="md:hidden">
                            <button type="button" class="main-nav__item main-nav__item--back relative js-back">
                              <div class="main-nav__item-content text-start">
                                {% render 'icon-chevron-left' %} {{- 'general.navigation.back' | t -}}
                              </div>
                            </button>
                          </li>

                          <li class="md:hidden">
                            <a href="{{ link.url }}" class="main-nav__item child-nav__item large-text main-nav__item-header">
                              {{- link.title | escape -}}
                            </a>
                          </li>

                          {%- for child_link in link.links -%}
                            {%- liquid
                              assign child_link_title_downcase = child_link.title | downcase
                              assign child_link_url_last_char = child_link.url | slice: -1
                              assign collection_image = false
                              assign is_swatch_finish = false

                              if mega_nav and mega_nav.settings.collection_images == "swatch"
                                assign is_swatch_finish = true
                              elsif mega_nav and mega_nav.settings.collection_images != "none" and child_link.type == 'collection_link'
                                assign collection_image = true
                                if mega_nav.settings.collection_images == "standard"
                                  assign collection_image_width = 30
                                elsif mega_nav.settings.collection_images == "large"
                                  assign collection_image_width = 40
                                endif
                                assign collection_image_size = collection_image_width
                                assign collection_image_size_large = collection_image_size | times: 2
                                assign alt_text = child_link.title | escape
                                assign collection_image_object = collections[child_link.object.handle].all_products.first.featured_image
                                if mega_nav.settings.collection_use_product_image == false
                                  assign collection_image_object = child_link.object.image | default: collection_image_object
                                endif
                              endif
                            -%}

                            {%- liquid
                              assign li_classes = ""
                              if flex_auto
                                assign li_classes = "flex-auto"
                              endif
                              if child_link.links != blank
                                if li_classes != ""
                                  assign li_classes = li_classes | append: " "
                                endif
                                assign li_classes = li_classes | append: "child-nav__item--toggle"
                                if mega_nav_has_columns and mega_nav.settings.show_underline == false
                                  assign li_classes = li_classes | append: " nav__item--no-underline"
                                endif
                                if mega_nav and mega_nav.type == "sidebar"
                                  assign li_classes = li_classes | append: " js-sidebar-hover"
                                  if forloop.first
                                    assign li_classes = li_classes | append: " is-visible"
                                  endif
                                endif
                              endif
                            -%}
                            <li{% if li_classes != "" %} class="{{ li_classes }}"{% endif %}>
                              {%- if child_link.links == blank -%}
                                {%- if is_swatch_finish -%}
                                  <a class="main-nav__item child-nav__item child-nav__item--swatch nav__item--no-underline"
                                     href="{{ child_link.url }}"{% if child_link.current %} aria-current="page"{% endif %}>
                                    {%- render 'tk-finish-swatch', finish_name: child_link.title, size: 60 -%}
                                    <span class="child-nav__item-swatch-label">{{ child_link.title | escape }}</span>
                                  </a>
                                {%- else -%}
                                {%- if collection_image -%}<div class="child-nav__item--toggle flex items-center child-nav__item-collection-image{% if mega_nav and mega_nav_has_columns and mega_nav.settings.show_underline == false %} nav__item--no-underline{% endif %}{% if mega_nav.type == "sidebar" %} js-sidebar-hover{% endif %}">{%- endif -%}
                                  {%- if collection_image -%}
                                    <div class="main-nav__collection-image media relative main-nav__collection-image--flex main-nav__collection-image--{{ mega_nav.settings.collection_images }}">
                                      {% render 'image',
                                        image: collection_image_object,
                                        src_width: collection_image_size_large,
                                        srcset_2x: true,
                                        class: "img-fit",
                                        alt_text: alt_text
                                      %}
                                    </div>
                                  {%- endif -%}
                                  <a class="main-nav__item child-nav__item{% if mega_nav and mega_nav_has_columns and mega_nav.settings.show_underline == false %} nav__item--no-underline{% endif %}{% if mega_nav.type == "sidebar" and forloop.first %} is-visible{% endif %}{% unless collection_image %}{% if mega_nav.type == "sidebar" %} js-sidebar-hover{% endif %}{% endunless %}"
                                      href="{{ child_link.url }}"{% if child_link.current %} aria-current="page"{% endif %}>
                                    {{- child_link.title | escape -}}
                                  </a>
                                {%- if collection_image -%}</div>{%- endif -%}
                                {%- endif -%}
                              {%- else -%}
                                {%- if mega_nav -%}
                                  <div class="main-nav__item-content{% if mega_nav.settings.collection_images != 'none' %} child-nav__collection-image w-full{% endif %}{% if featured_links contains child_link_title_downcase %} main-nav__link--featured{% endif %}">
                                    {%- if collection_image -%}
                                      <div class="main-nav__collection-image main-nav__collection-image--flex main-nav__collection-image--{{ mega_nav.settings.collection_images }} media relative">
                                        {% render 'image',
                                          image: collection_image_object,
                                          src_width: collection_image_size_large,
                                          srcset_2x: true,
                                          class: "img-fit",
                                          alt_text: alt_text
                                        %}
                                      </div>
                                    {%- endif -%}
                                    <a class="child-nav__item main-nav__item{% if child_link.current %} is-active{% endif %}{% if mega_nav.type == 'sidebar' %} md:flex md:items-center{% endif %}" href="{{ child_link.url }}"{% if settings.preload_links %} data-no-instant{% endif %}>
                                      {{- child_link.title | escape -}}
                                      {%- if mega_nav.type == 'sidebar' -%}
                                        <div class="hidden md:inline-flex main-nav__icon-circle">
                                          {%- render 'icon-chevron-down' -%}
                                        </div>
                                      {%- endif -%}
                                    </a>
                                    <button type="button" class="main-nav__toggle-btn js-toggle" aria-expanded="false" aria-controls="nav-dropdown-{{ forloop.parentloop.index }}-{{ forloop.index }}" aria-label="{{ 'accessibility.toggle_submenu' | t: title: child_link.title | escape }}">
                                      {%- render 'icon-chevron-down' -%}
                                    </button>
                                  </div>
                                  <div class="child-nav__panel has-motion" id="nav-dropdown-{{ forloop.parentloop.index }}-{{ forloop.index }}">
                                    {%- liquid
                                      assign image_grid_classes = ""
                                      if mega_nav.type == "sidebar"
                                        for grandchild_link in child_link.links
                                          if mega_nav.settings.show_collection_images and grandchild_link.type == 'collection_link'
                                            assign image_grid_classes = "main-nav__grandchild-grid grid grid-cols-2 gap-theme"
                                            break
                                          elsif mega_nav.settings.show_product_images and grandchild_link.type == 'product_link'
                                            assign image_grid_classes = "main-nav__grandchild-grid grid grid-cols-2 gap-theme"
                                            break
                                          endif
                                        endfor
                                      endif
                                    -%}

                                    <ul class="main-nav__grandchild has-motion{% if image_grid_classes %} {{ image_grid_classes }}{% endif %}{% if grandchild_nav_classes %} {{ grandchild_nav_classes }}{% endif %}" role="list"{% if badge_colors %} style="{{ badge_colors }}"{% endif %}>
                                      {%- for grandchild_link in child_link.links -%}
                                        <li>
                                          {%- assign grandchild_link_title_downcase = grandchild_link.title | downcase -%}
                                          <a class="grandchild-nav__item main-nav__item{% if featured_links contains grandchild_link_title_downcase %} main-nav__link--featured{% endif %}" href="{{ grandchild_link.url }}"{% if grandchild_link.current %} aria-current="page"{% endif %}>
                                            {%- liquid
                                              assign grandchild_image = null
                                              if mega_nav.type == "sidebar"
                                                if mega_nav.settings.show_collection_images and grandchild_link.type == 'collection_link'
                                                  if mega_nav.settings.sidebar_link_use_product_image
                                                    assign grandchild_image = collections[grandchild_link.object.handle].all_products.first
                                                    if grandchild_image == blank
                                                      assign grandchild_image = grandchild_link.object
                                                    endif
                                                  else
                                                    assign grandchild_image = grandchild_link.object
                                                  endif
                                                elsif mega_nav.settings.show_product_images and grandchild_link.type == 'product_link'
                                                  assign grandchild_image = grandchild_link.object
                                                endif
                                              endif
                                            -%}

                                            {%- if grandchild_image -%}
                                              <div class="media relative mb-2 w-full grandchild-nav__image{% if settings.blend_product_images and grandchild_link.type == 'product_link' %} image-blend{% elsif settings.blend_collection_images and grandchild_link.type == 'collection_link' %} image-blend{% endif %}"{%- if mega_nav.settings.aspect_ratio != "natural" -%} style="padding-top: {{ 1 | divided_by: mega_nav.settings.aspect_ratio | times: 100 }}%;"{%- endif -%}>
                                                {%- if mega_nav.settings.aspect_ratio == "natural" -%}
                                                  {%- capture image -%}{% render 'image', image: grandchild_image, src_width: 300, class: 'w-full', alt_text: grandchild_link.title %}{%- endcapture -%}
                                                {%- else -%}
                                                  {%- liquid
                                                    assign image_width = 300
                                                    assign image_height = image_width | divided_by: mega_nav.settings.aspect_ratio | round
                                                  -%}
                                                  {%- capture image -%}
                                                    <img src="{{ grandchild_image | image_url: width: image_width, height: image_height, crop: 'center' }}"
                                                      class="img-fit"
                                                      loading="lazy"
                                                      alt="{{ grandchild_link.title | escape }}"
                                                      height="{{ image_height }}"
                                                      width="{{ image_width }}">
                                                  {%- endcapture -%}
                                                {%- endif -%}

                                                {%- unless image contains "Liquid error" -%}
                                                  {{ image }}
                                                {%- endunless -%}
                                              </div>
                                            {%- endif -%}

                                            {%- if has_badges -%}
                                              {%- assign grandchild_link_title_downcase = grandchild_link.title | downcase -%}
                                              {%- if badge1 and badge1 contains grandchild_link_title_downcase -%}
                                                <span class="md:mr-2">{{- grandchild_link.title | escape -}}</span>
                                                <span class="badge main-nav__badge main-nav__badge--1">{{ mega_nav.settings.badge1_text }}</span>
                                              {% elsif badge2 and badge2 contains grandchild_link_title_downcase -%}
                                                <span class="md:mr-2">{{- grandchild_link.title | escape -}}</span>
                                                <span class="badge main-nav__badge main-nav__badge--2">{{ mega_nav.settings.badge2_text }}</span>
                                              {% elsif badge3 and badge3 contains grandchild_link_title_downcase -%}
                                                <span class="md:mr-2">{{- grandchild_link.title | escape -}}</span>
                                                <span class="badge main-nav__badge main-nav__badge--3">{{ mega_nav.settings.badge3_text }}</span>
                                              {%- else -%}
                                                {{- grandchild_link.title | escape -}}
                                              {%- endif -%}
                                            {%- else -%}
                                              {{- grandchild_link.title | escape -}}
                                            {%- endif -%}
                                          </a>
                                        </li>
                                      {%- endfor -%}

                                      {%- if section.settings.repeat_links and child_link_url_last_char != '#' -%}
                                        <li class="col-start-1 col-end-3">
                                          <a href="{{ child_link.url }}" class="main-nav__item--go">
                                            {{- 'sections.header.go_to' | t: title: child_link.title -}}{% render 'icon-chevron-right' %}
                                          </a>
                                        </li>
                                      {%- endif -%}
                                    </ul>
                                  </div>
                                {%- else -%}
                                  <div class="main-nav__item-content{% if featured_links contains child_link_title_downcase %} main-nav__link--featured{% endif %}">
                                    <a class="child-nav__item main-nav__item{% if child_link.current %} is-active{% endif %}" href="{{ child_link.url }}"{% if settings.preload_links %} data-no-instant{% endif %}>
                                      {{- child_link.title | escape -}}
                                      {%- if mega_nav.type == 'sidebar' -%}
                                        <div class="hidden md:inline-flex main-nav__icon-circle">
                                          {%- render 'icon-chevron-down' -%}
                                        </div>
                                      {%- endif -%}
                                    </a>
                                    <button type="button" class="main-nav__toggle-btn js-toggle" aria-expanded="false" aria-controls="nav-dropdown-{{ forloop.parentloop.index }}-{{ forloop.index }}" aria-label="{{ 'accessibility.toggle_submenu' | t: title: child_link.title | escape }}">
                                      {%- render 'icon-chevron-down' -%}
                                    </button>
                                  </div>
                                  <div class="child-nav__panel has-motion" id="nav-dropdown-{{ forloop.parentloop.index }}-{{ forloop.index }}">
                                    <ul class="main-nav__grandchild has-motion" role="list">
                                      {%- for grandchild_link in child_link.links -%}
                                        <li>
                                          {%- assign grandchild_link_title_downcase = grandchild_link.title | downcase -%}
                                          <a class="grandchild-nav__item main-nav__item relative{% if featured_links contains grandchild_link_title_downcase %} main-nav__link--featured{% endif %}" href="{{ grandchild_link.url }}"{% if grandchild_link.current %} aria-current="page"{% endif %}>
                                            {{- grandchild_link.title | escape -}}
                                          </a>
                                        </li>
                                      {%- endfor -%}

                                      {%- if section.settings.repeat_links and child_link_url_last_char != '#' -%}
                                        <li class="col-start-1 col-end-3">
                                          <a href="{{ child_link.url }}" class="main-nav__item--go">
                                            {{- 'sections.header.go_to' | t: title: child_link.title -}}{% render 'icon-chevron-right' %}
                                          </a>
                                        </li>
                                      {%- endif -%}
                                    </ul>
                                  </div>
                                {%- endif -%}
                              {%- endif -%}
                            </li>
                          {%- endfor -%}
                        </ul>

                        {%- if mega_nav and promo_count > 0 -%}
                          <div class="child-promos" data-promo-count="{{ promo_count }}">
                            <div class="main-nav__promos mt-12 md:nav-mt-4 sm:nav-gap-x-6 sm:grid{% if promo_count < 3 %} sm:grid-cols-2{% else %} sm:nav-grid-cols-3{% endif %}{% if mega_nav.settings.promo_position == "bottom" %} lg:grid-cols-3{% else %} lg:block{% endif %}"
                              style="--promo-text-color: {{- mega_nav.settings.promo_text_color -}};--promo-min-height: {{- mega_nav.settings.promo_min_height -}}px;--promo-overlay-color: rgba({{ mega_nav.settings.promo_tint_color.red }}, {{ mega_nav.settings.promo_tint_color.green }}, {{ mega_nav.settings.promo_tint_color.blue }}, {{ mega_nav.settings.promo_tint_opacity | divided_by: 100.0 }});">
                              {%- liquid
                                if mega_nav.settings.promo_min_height > 250
                                  assign promo_padding = "p-8"
                                elsif mega_nav.settings.promo_min_height > 150
                                  assign promo_padding = "p-6"
                                else
                                  assign promo_padding = "p-4"
                                endif
                              -%}

                              {%- if mega_nav.settings.promo1_content != blank or mega_nav.settings.promo1_image != blank -%}
                                {%- render 'menu-promo',
                                  promo_image: mega_nav.settings.promo1_image,
                                  promo_content: mega_nav.settings.promo1_content,
                                  promo_link_url: mega_nav.settings.promo1_link_url,
                                  promo_text_alignment: mega_nav.settings.promo1_text_alignment,
                                  promo_text_size: mega_nav.settings.promo1_text_size,
                                  promo_text_width: mega_nav.settings.promo1_text_width,
                                  promo_custom_class: promo_padding
                                -%}
                              {%- endif -%}

                              {%- if mega_nav.settings.promo2_content != blank or mega_nav.settings.promo2_image != blank -%}
                                {%- render 'menu-promo',
                                  promo_image: mega_nav.settings.promo2_image,
                                  promo_content: mega_nav.settings.promo2_content,
                                  promo_link_url: mega_nav.settings.promo2_link_url,
                                  promo_text_alignment: mega_nav.settings.promo2_text_alignment,
                                  promo_text_size: mega_nav.settings.promo2_text_size,
                                  promo_text_width: mega_nav.settings.promo2_text_width,
                                  promo_custom_class: promo_padding
                                -%}
                              {%- endif -%}

                              {%- if mega_nav.settings.promo3_content != blank or mega_nav.settings.promo3_image != blank -%}
                                {%- render 'menu-promo',
                                  promo_image: mega_nav.settings.promo3_image,
                                  promo_content: mega_nav.settings.promo3_content,
                                  promo_link_url: mega_nav.settings.promo3_link_url,
                                  promo_text_alignment: mega_nav.settings.promo3_text_alignment,
                                  promo_text_size: mega_nav.settings.promo3_text_size,
                                  promo_text_width: mega_nav.settings.promo3_text_width,
                                  promo_custom_class: promo_padding
                                -%}
                              {%- endif -%}
                            </div>
                          </div>
                        {%- endif -%}

                      {%- if mega_nav -%}</div>{%- endif -%}
                    </div>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>

          {%- if section.settings.cta_show -%}
            <nav aria-label="{{ 'accessibility.secondary_navigation' | t }}" class="secondary-nav-container">
              <ul class="secondary-nav js-closes-menu" role="list">
                {%- assign cta_bg_color_hover = section.settings.cta_bg_color | color_mix: section.settings.cta_text_color, 85 | color_lighten: 3 -%}
                <li class="inline-flex items-center self-center">
                  <a href="{{ section.settings.cta_link }}" class="secondary-nav__item secondary-nav__cta{% if section.settings.cta_bg_color.alpha > 0 or section.settings.cta_border_color.alpha > 0 %} secondary-nav__cta--button{% endif %} flex items-center"{% if link.current %} aria-current="page"{% endif %}
                    style="{% if section.settings.cta_bg_color.alpha > 0 %}--cta-bg-color: {{ section.settings.cta_bg_color.rgb }};--cta-bg-hover-color: {{ cta_bg_color_hover.rgb }};{% endif %}color: {{ section.settings.cta_text_color }};{% if section.settings.cta_border_color.alpha > 0 %}border: var(--btn-border-width, 1px) solid {{ section.settings.cta_border_color }};{% endif %}">
                    {%- if section.settings.cta_icon != "none" -%}
                      {%- render 'icon', icon: section.settings.cta_icon, width: 17, height: 17 -%}
                    {%- endif -%}
                    {%- if section.settings.cta_label != blank -%}
                      <span>{{ section.settings.cta_label }}</span>
                    {%- endif -%}
                  </a>
                </li>
              </ul>
            </nav>
          {%- endif -%}
        </div>
      </main-menu>
    {%- endif -%}
  </header>
</store-header>

{%- if has_mega_nav_columns -%}
  <link rel="stylesheet" href="{{ 'navigation-mega-columns.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if has_mega_nav_sidebar -%}
  <link rel="stylesheet" href="{{ 'navigation-mega-sidebar.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if total_promo_count > 0 -%}
  <link rel="stylesheet" href="{{ 'promos.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'navigation-promos.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

