{%- liquid
  assign found_highlight_text = false

  # constants
  assign gutter_sm = 20
  assign breakpoint_lg = 1024

  assign color_scheme = section.settings.color_scheme
  assign bg_color = false

  if color_scheme == 'default'
    assign bg_color = settings.bg_color
  elsif color_scheme == '1'
    assign bg_color = settings.color_scheme_1_bg_grad | default: settings.color_scheme_1_bg
  elsif color_scheme == '2'
    assign bg_color = settings.color_scheme_2_bg_grad | default: settings.color_scheme_2_bg
  elsif color_scheme == '3'
    assign bg_color = settings.color_scheme_3_bg_grad | default: settings.color_scheme_3_bg
  endif

  if bg_color == 'rgba(0,0,0,0)'
    assign bg_color = false
  endif
-%}

{%- if section.blocks.size > 0 or section.settings.text != blank or section.settings.image != blank -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.show_reviews and block.settings.custom_reviews == blank and block.type == 'tabs' -%}
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          if (document.getElementById('shopify-product-reviews')) {
            const link = document.createElement('link');
            link.rel = "stylesheet";
            link.href = "{{ 'reviews.css' | asset_url }}";
            document.body.appendChild(link);
          }
        }, { once: true });
      </script>
    {%- elsif block.type == 'highlight-text' and found_highlight_text == false -%}
      <link rel="stylesheet" href="{{ 'product-highlights.css' | asset_url }}" media="print" onload="this.media='all'">
      {%- assign found_highlight_text = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- style -%}
    {%- if bg_color -%}
      .product-details { background: {{ bg_color }}; }
    {%- endif -%}

    {%- if section.settings.content_size == 'large' -%}
      @media (min-width: {{ breakpoint_lg }}px) {
        .product-details { --product-info-width: {% if settings.dock_cart_drawer and settings.cart_type == 'drawer' %}400{% else %}440{% endif %}px !important; }
      }
    {%- endif -%}
  {%- endstyle -%}

  <div class="section{% unless color_scheme == 'default' %} xs:section--mb-0{% if section.settings.full_width %} color-scheme color-scheme--{{ color_scheme }}{% endif %}{% endunless %}">
    <div class="container{% if section.settings.text == blank and section.settings.image == blank %} reading-width{% endif %} product-details{% unless color_scheme == 'default' %}{% if section.settings.full_width == false %} color-scheme color-scheme--{{ color_scheme }}{% endif %} section--padded-y{% else %} xs:section--padded-top section--padded-bottom{% endunless %}" data-section-id="{{ section.id }}">
      {% if section.settings.text != blank or section.settings.image != blank %}
        <div class="product-details__grid grid md:grid-flow-col auto-cols-1 md:auto-cols-2">
          <div class="product-details__left{% if section.settings.placement == 'right' %} order-2{% endif %}">
            <div class="sticky product-details--left">
              {% if section.settings.image != blank %}
                {%- capture image -%}
                  <div class="mb-8 last:mb-0">
                    {%- capture sizes_md %}calc((50vw - {{ gutter_sm | times: 2 }}px) + 9px){% endcapture -%}
                    {%- capture sizes -%}
                      {%- render 'sizes-attribute', min: 'page', sm: 'page', md: sizes_md, lg: '536px', xl: false, max: false -%}
                    {%- endcapture -%}
                    {% render 'image',
                      image: section.settings.image,
                      widths: '536, 800, 1072, 1280',
                      mobile_widths: '690, 800',
                      src_width: 536,
                      sizes: sizes,
                      section_index: section.index
                    %}
                  </div>
                {%- endcapture -%}
              {% endif %}

              {% if section.settings.show_image_first and image %}
                {{ image }}
              {% endif %}

              {% if section.settings.text != blank %}
                <div class="rte mb-8 last:mb-0">
                  {{ section.settings.text }}
                </div>
              {% endif %}

              {% if section.settings.show_image_first == false and image %}
                {{ image }}
              {% endif %}
            </div>
          </div>
          <div class="product-details__right{% if section.settings.placement == 'right' %} order-1{% endif %}">
      {% endif %}


      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            <div class="product-details__block" {{ block.shopify_attributes }}>
              {% render block %}
            </div>

          {%- when 'tabs' -%}
            {%- liquid
              assign tabs = ''
              if block.settings.show_description
                assign tabs = ',0'
              endif
              if block.settings.show_specification
                assign tabs = tabs | append: ',4'
              endif
              if block.settings.show_reviews
                assign tabs = tabs | append: ',5'
              endif
              if block.settings.tab_1_title != blank or block.settings.tab_1_page.title != blank
                assign tabs = tabs | append: ',1'
              endif
              if block.settings.tab_2_title != blank or block.settings.tab_2_page.title != blank
                assign tabs = tabs | append: ',2'
              endif
              if block.settings.tab_3_title != blank or block.settings.tab_3_page.title != blank
                assign tabs = tabs | append: ',3'
              endif
              assign tab_indices = tabs | remove_first: ',' | split: ','
            -%}

            {%- if block.settings.show_specification and block.settings.spec_metafields -%}
              {%- capture specification -%}
                {%- assign metafield_array = block.settings.spec_metafields | newline_to_br | strip_newlines | split: '<br />' -%}
                {%- for key_value in metafield_array -%}
                  {%- liquid
                    assign parts = key_value | split: ':'
                    assign label = parts.first | strip | replace: '"', ''
                    assign metafield_key = parts.last | strip
                    assign metafield_key_parts = metafield_key | split: "."
                    assign metafield_namespace_index = metafield_key_parts | size | minus: 2
                    assign metafield_key = metafield_key_parts | last
                    assign metafield_namespace = metafield_key_parts[metafield_namespace_index]
                    assign metafield = product.metafields[metafield_namespace][metafield_key]

                    capture metafield_output
                      if metafield.type contains "list.metaobject_reference"
                        render 'render-metafield', metafield: metafield, metafield_type: metafield.type, metafield_value: metafield.value
                      elsif metafield.type contains "list."
                        for item in metafield.value
                          assign metafield_type = metafield.type | replace: "list.", ""
                          assign comma = ""
                          if forloop.last == false
                            assign comma = ", "
                          endif
                          render 'render-metafield', metafield: metafield, metafield_type: metafield_type, metafield_value: item, comma: comma
                          if forloop.last == false and metafield_type == "file_reference"
                            echo "<div class='mt-2'></div>"
                          endif
                        endfor
                      elsif metafield.value
                        render 'render-metafield', metafield: metafield, metafield_type: metafield.type, metafield_value: metafield.value
                      endif
                    endcapture
                  -%}
                  {%- unless metafield_output contains "Liquid error" -%}
                    {%- unless metafield_output == blank and block.settings.spec_show_empty_metafields == false -%}
                      <li class="product-spec__item flex flex-col gap-x-theme md:flex-row pb-4 mb-4 last:pb-0 last:mb-0">
                        <div class="product-spec__label{% if block.settings.spec_right_align %} product-spec__label--right{% endif %} mb-2 block font-bold">
                          {{ label }}
                        </div>
                        <div class="product-spec__value {% if metafield.type contains "color" %}flex flex-wrap gap-3{% else %}block{% endif %}{% if block.settings.spec_right_align %} text-end justify-end grow{% endif %}">
                          {%- if metafield_output == blank -%}
                            {{ block.settings.spec_empty_field_text }}
                          {%- else -%}
                            {{ metafield_output }}
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endunless -%}
                  {%- endunless -%}
                {%- endfor -%}
              {%- endcapture -%}
            {%- endif -%}

            {%- assign first_tab_rendered = false -%}

            {%- if tabs.size > 0 -%}
              <div class="product-details__block" {{ block.shopify_attributes }}>
                {%- for i in tab_indices -%}
                  {%- liquid
                    assign prevent_tab_render = false

                    if i == '0'
                      assign title = 'products.product.description' | t
                    elsif i == '4' and specification == blank
                      assign title = block.settings.spec_heading
                      assign prevent_tab_render = true
                    elsif i == '4'
                      assign title = block.settings.spec_heading
                    elsif i == '5' and block.settings.show_reviews
                      assign rating_count = product.metafields.reviews.rating_count | plus: 0
                      assign title = 'products.product.reviews' | t
                      if block.settings.show_reviews_count
                        assign title = title | append: ' (' | append: rating_count | append: ')'
                      endif
                    else
                      assign title_id = 'tab_' | append: i | append: '_title'
                      assign text_id = 'tab_' | append: i | append: '_text'
                      assign page_id = 'tab_' | append: i | append: '_page'
                      assign title = block.settings[title_id] | default: block.settings[page_id].title
                    endif
                  -%}

                  {%- if block.settings.style == 'collapsible' and prevent_tab_render == false -%}
                    <details-disclosure>
                      <details class="disclosure disclosure--row"{% if first_tab_rendered == false and block.settings.open_first %} open{% endif %}>
                        <summary>
                          <div class="flex justify-between items-center" data-dynamic-product-content="{{ section.id }}-{{ block.id }}-{{ forloop.index }}-summary">
                            <h2 class="disclosure__title h5 mb-0">{{ title }}</h2>
                            <span class="disclosure__toggle">
                              {%- if settings.disclosure_toggle == 'plus' -%}
                                {% render 'icon-plus' %}
                              {%- else -%}
                                {% render 'icon-chevron-down' %}
                              {%- endif -%}
                            </span>
                          </div>
                        </summary>
                        <div class="disclosure__panel has-motion">
                          <div class="disclosure__content{% unless i == "4" %} rte product-description{% endunless %}" data-dynamic-product-content="{{ section.id }}-{{ block.id }}-{{ forloop.index }}-content">
                            {%- if forloop.first and block.settings.show_description -%}
                              {{ product.description }}
                            {%- elsif i == "4"  and specification != blank -%}
                              <ul class="product-spec">
                                {{ specification }}
                              </ul>
                            {%- elsif i == "5" and block.settings.show_reviews -%}
                              {%- if block.settings.custom_reviews == blank -%}
                                <div class="spr-reviews" id="shopify-product-reviews" data-id="{{ product.id }}">
                                  {{ product.metafields.spr.reviews }}
                                </div>
                              {%- else -%}
                                <div class="custom-reviews">
                                  {{ block.settings.custom_reviews }}
                                </div>
                              {%- endif -%}
                            {%- else -%}
                              {{ block.settings[text_id] }}
                              {{ block.settings[page_id].content }}
                            {%- endif -%}
                          </div>
                        </div>
                      </details>
                    </details-disclosure>
                    {%- assign first_tab_rendered = true -%}
                  {%- else -%}
                    {%- capture tab_btns -%}
                      {{ tab_btns }}
                      <button type="button" class="tablist__tab font-bold" id="tab-{{ i }}" role="tab" aria-controls="panel-{{ i }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
                        <span data-dynamic-product-content="{{ section.id }}-{{ block.id }}-{{ forloop.index }}-tab">
                          {{ title }}
                        </span>
                      </button>
                    {%- endcapture -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- if block.settings.style == 'tabs' -%}
                  <tabbed-content>
                    <div class="tablist overflow-hidden relative mb-4 no-js-hidden">
                      <div class="tablist__scroller flex" role="tablist">
                        {{ tab_btns }}
                      </div>
                    </div>
                    {%- for i in tab_indices -%}
                      {%- liquid
                        assign text_id = 'tab_' | append: i | append: '_text'
                        assign page_id = 'tab_' | append: i | append: '_page'
                      -%}
                      <div id="panel-{{ i }}" role="tabpanel" tabindex="0" aria-labelledby="tab-{{ i }}"{% unless forloop.first %} hidden{% endunless %}>
                        <div data-dynamic-product-content="{{ section.id }}-{{ block.id }}-{{ forloop.index }}-tabpanel">
                          {%- if forloop.first and block.settings.show_description -%}
                            <div class="rte product-description">
                              {{ product.description }}
                            </div>
                          {%- elsif i == "4" and specification != blank -%}
                            <ul class="product-spec">
                              {{ specification }}
                            </ul>
                          {%- elsif i == "5" and block.settings.show_reviews -%}
                            {%- if block.settings.custom_reviews == blank -%}
                              <div class="spr-reviews" id="shopify-product-reviews" data-id="{{ product.id }}">
                                {{ product.metafields.spr.reviews }}
                              </div>
                            {%- else -%}
                              <div class="custom-reviews">
                                {{ block.settings.custom_reviews }}
                              </div>
                            {%- endif -%}
                          {%- else -%}
                            <div class="rte">
                              {{ block.settings[text_id] }}
                              {{ block.settings[page_id].content }}
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endfor -%}
                  </tabbed-content>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.style == 'tabs' -%}
              <script src="{{ 'tabs.js' | asset_url }}" defer="defer"></script>
            {%- endif -%}

          {%- when 'richtext' -%}
            <div class="product-details__block product-details__text rte" data-dynamic-product-content="{{ section.id }}-{{ block.id }}"{% if block.settings.text == blank %} hidden{% endif %} {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'custom-liquid' -%}
            <div class="product-details__block"{% if block.settings.variant_content %} data-dynamic-variant-content="{{ section.id }}-{{ block.id }}"{% endif %}{% if block.settings.custom_liquid == blank %} hidden{% endif %} {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>

          {%- when 'divider' -%}
            <hr class="mt-6 mb-6{% unless block.settings.show_line %} invisible{% endunless %}" {{ block.shopify_attributes }}>

          {%- when 'highlight-text' -%}
            {%- liquid
              assign last_section_index = forloop.index0 | minus: 1
              assign next_section_index = forloop.index
              assign last_section_was_highlight = false
              assign next_section_is_highlight = false

              if last_section_index > -1 and section.blocks[last_section_index].type == 'highlight-text'
                assign last_section_was_highlight = true
              endif

              if section.blocks[next_section_index].type == 'highlight-text'
                assign next_section_is_highlight = true
              endif
            -%}

            {%- if last_section_was_highlight == false and next_section_is_highlight -%}
              <div class="product-details__block product-details__highlight-grid grid sm:grid-cols-2 md:grid-cols-1 lg:grid-cols-2">
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="{% unless last_section_was_highlight or next_section_is_highlight %}product-details__block {% endunless %}product-details__highlight text-center" data-dynamic-product-content="{{ section.id }}-{{ block.id }}" {{ block.shopify_attributes }}>
                <div class="rte large-text">{{ block.settings.text }}</div>
              </div>
            {%- endif -%}

            {%- if last_section_was_highlight and next_section_is_highlight == false -%}
              </div>
            {%- endif -%}

          {%- when 'payment-methods' -%}
            <div class="product-details__block panel{% if color_scheme != "default" %} panel--camo{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h3 class="h5 mb-6">{{- block.settings.title | escape -}}</h3>
              {%- endif -%}

              {%- if block.settings.title1 != blank -%}
                <p class="h6 regular-text mb-4" id="payment-methods-title">{{- block.settings.title1 | escape -}}</p>
              {%- endif -%}

              {%- if block.settings.show_payment_icons -%}
                <div class="mb-4">
                  <ul class="payment-icons flex flex-wrap" role="list" {%- if block.settings.title1 != blank -%}aria-labelledby="payment-methods-title"{% endif %}>
                    {%- for type in shop.enabled_payment_types -%}
                      <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

              {%- if block.settings.text1 != blank -%}
                <div class="rte mb-4">{{ block.settings.text1 }}</div>
              {%- endif -%}

              {%- if block.settings.title2 != blank -%}
                <p class="h6 regular-text mb-4 mt-8">{{- block.settings.title2 | escape -}}</p>
              {%- endif -%}

              {%- if block.settings.image -%}
                {% render 'image',
                  image: block.settings.image,
                  src_width: block.settings.image.width,
                  class: "mb-4"
                %}
              {%- endif -%}

              {%- if block.settings.text2 != blank -%}
                <div class="rte mb-4">{{ block.settings.text2 }}</div>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}

      {% if section.settings.text != blank or section.settings.image != blank %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product details",
  "class": "cc-product-details cc-variant-dependent-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Side content shows next to \"Product details\" blocks on large screens."
    },
    {
      "type": "select",
      "id": "content_size",
      "label": "Side content width",
      "options": [
        {
          "value": "default",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "Side content placement",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<h3>Key product features<\/h3><p>Can be highlighted here.<\/p>",
      "label": "Side text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side image"
    },
    {
      "type": "checkbox",
      "id": "show_image_first",
      "label": "Show the image first",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "1",
          "label": "Scheme 1"
        },
        {
          "value": "2",
          "label": "Scheme 2"
        },
        {
          "value": "3",
          "label": "Scheme 3"
        }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section background full width",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom Liquid"
        },
        {
          "type": "checkbox",
          "id": "variant_content",
          "label": "Update when variant changes",
          "default": false
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_line",
          "label": "Show line",
          "info": "The space will still be present when the line is hidden.",
          "default": true
        }
      ]
    },
    {
      "type": "richtext",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Rich text",
          "default": "<p>Share information about this product with your customers.</p>"
        }
      ]
    },
    {
      "type": "tabs",
      "name": "Tabs",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Tabs style",
          "options": [
            {
              "value": "collapsible",
              "label": "Collapsible content"
            },
            {
              "value": "tabs",
              "label": "Horizontal tabs"
            }
          ],
          "default": "collapsible"
        },
        {
          "visible_if": "{{ block.settings.style == 'collapsible' }}",
          "type": "checkbox",
          "id": "open_first",
          "label": "Open first collapsible tab by default",
          "default": false
        },
        {
          "type": "header",
          "content": "Description tab"
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show description tab",
          "default": true
        },
        {
          "type": "header",
          "content": "Reviews tab"
        },
        {
          "type": "checkbox",
          "id": "show_reviews",
          "label": "Show reviews tab",
          "default": false
        },
        {
          "visible_if": "{{ block.settings.show_reviews }}",
          "type": "checkbox",
          "id": "show_reviews_count",
          "label": "Show reviews count",
          "default": true
        },
        {
          "visible_if": "{{ block.settings.show_reviews }}",
          "type": "liquid",
          "id": "custom_reviews",
          "label": "Custom reviews app code",
          "info": "Used to show reviews in a tab if Shopify Product Reviews app is not installed."
        },
        {
          "type": "header",
          "content": "Specifications tab"
        },
        {
          "type": "paragraph",
          "content": "Include a list of labels and product metafield keys below, separated by a colon, one per line. E.g. Trim color:custom.trim_color. [Read more](https://cleancanvas.co.uk/support/canopy/templates/product-page)"
        },
        {
          "type": "checkbox",
          "id": "show_specification",
          "label": "Show specifications tab",
          "default": false
        },
        {
          "visible_if": "{{ block.settings.show_specification }}",
          "type": "text",
          "id": "spec_heading",
          "label": "Heading",
          "default": "Specifications"
        },
        {
          "visible_if": "{{ block.settings.show_specification }}",
          "type": "textarea",
          "id": "spec_metafields",
          "label": "Metafields"
        },
        {
          "visible_if": "{{ block.settings.show_specification }}",
          "type": "checkbox",
          "id": "spec_right_align",
          "label": "Right align values",
          "default": false
        },
        {
          "visible_if": "{{ block.settings.show_specification }}",
          "type": "checkbox",
          "id": "spec_show_empty_metafields",
          "label": "Show empty metafields",
          "default": true
        },
        {
          "visible_if": "{{ block.settings.show_specification }}",
          "type": "text",
          "id": "spec_empty_field_text",
          "label": "Text to use for empty fields",
          "default": "-"
        },
        {
          "type": "header",
          "content": "Custom tabs"
        },
        {
          "type": "paragraph",
          "content": "Show up to 3 custom tabs by adding a title and content or selecting a page"
        },
        {
          "type": "header",
          "content": "Tab 1"
        },
        {
          "type": "text",
          "id": "tab_1_title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "tab_1_text",
          "label": "Content"
        },
        {
          "type": "page",
          "id": "tab_1_page",
          "label": "Content from page"
        },
        {
          "type": "header",
          "content": "Tab 2"
        },
        {
          "type": "text",
          "id": "tab_2_title",
          "label": "Title"
        },
        {
