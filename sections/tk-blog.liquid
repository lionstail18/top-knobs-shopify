<!-- Header -->
<div class="tk-blog__header">
  <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
  <h1 class="tk-blog__h1">{{ blog.title | default: section.settings.heading | escape }}</h1>
  <p class="tk-blog__intro">{{ section.settings.intro | escape }}</p>
</div>

<!-- Category filters -->
{%- assign all_tags = blog.all_tags -%}
{%- if all_tags.size > 0 -%}
  <div class="tk-blog__filters">
    <a href="{{ blog.url }}" class="tk-blog__filter{% unless current_tags %} tk-blog__filter--active{% endunless %}">All</a>
    {%- for tag in all_tags -%}
      <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="tk-blog__filter{% if current_tags contains tag %} tk-blog__filter--active{% endif %}">{{ tag }}</a>
    {%- endfor -%}
  </div>
{%- endif -%}

<!-- Featured + Grid -->
{%- assign articles_list = blog.articles -%}
{%- if articles_list.size > 0 -%}
  {%- assign featured = articles_list.first -%}
  <article class="tk-blog__featured">
    <a href="{{ featured.url }}" class="tk-blog__featured-link">
      <div class="tk-blog__featured-media">
        {%- if featured.image != blank -%}
          {{- featured.image | image_url: width: 1400 | image_tag:
              loading: 'eager',
              class: 'tk-blog__featured-img',
              alt: featured.title | escape -}}
        {%- else -%}
          <div class="tk-blog__featured-img tk-blog__featured-img--placeholder"></div>
        {%- endif -%}
      </div>
      <div class="tk-blog__featured-body">
        {%- if featured.tags.size > 0 -%}
          <span class="tk-blog__category">{{ featured.tags.first }}</span>
        {%- endif -%}
        <h2 class="tk-blog__featured-title">{{ featured.title | escape }}</h2>
        <p class="tk-blog__featured-excerpt">{{ featured.excerpt_or_content | strip_html | truncatewords: 32 }}</p>
        <p class="tk-blog__featured-meta">
          <span>{{ featured.published_at | date: '%B %-d, %Y' }}</span>
          <span aria-hidden="true">·</span>
          <span>Read article &rarr;</span>
        </p>
      </div>
    </a>
  </article>

  <div class="tk-blog__grid">
    {%- for article in articles_list offset: 1 -%}
      <article class="tk-blog__card">
        <a href="{{ article.url }}" class="tk-blog__card-link">
          <div class="tk-blog__card-media">
            {%- if article.image != blank -%}
              {{- article.image | image_url: width: 700 | image_tag:
                  loading: 'lazy',
                  class: 'tk-blog__card-img',
                  alt: article.title | escape -}}
            {%- else -%}
              <div class="tk-blog__card-img tk-blog__card-img--placeholder"></div>
            {%- endif -%}
          </div>
          <div class="tk-blog__card-body">
            {%- if article.tags.size > 0 -%}
              <span class="tk-blog__category">{{ article.tags.first }}</span>
            {%- endif -%}
            <h3 class="tk-blog__card-title">{{ article.title | escape }}</h3>
            <p class="tk-blog__card-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
            <p class="tk-blog__card-meta">{{ article.published_at | date: '%B %-d, %Y' }}</p>
          </div>
        </a>
      </article>
    {%- endfor -%}
  </div>
{%- else -%}
  <div class="tk-blog__empty">
    <p class="tk-blog__empty-text">No articles published yet. Check back soon.</p>
  </div>
{%- endif -%}

{%- style -%}
  .tk-blog__header {
    padding: 72px var(--tk-page-x) 32px;
    text-align: center;
    background: var(--color-bg);
  }
  .tk-blog__header .tk-eyebrow { margin: 0 0 10px; }
  .tk-blog__h1 {
    font-family: var(--tk-font-heading);
    font-size: 52px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 16px;
    line-height: 1.05;
  }
  .tk-blog__intro {
    font-family: var(--tk-font-body);
    font-size: 14px;
    color: var(--color-text2);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .tk-blog__filters {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 0 var(--tk-page-x) 32px;
  }
  .tk-blog__filter {
    padding: 8px 16px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--tk-font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tk-blog__filter--active,
  .tk-blog__filter:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .tk-blog__featured {
    margin: 0 var(--tk-page-x) 56px;
  }
  .tk-blog__featured-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    text-decoration: none;
    color: inherit;
    align-items: center;
  }
  .tk-blog__featured-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .tk-blog__featured-img--placeholder { background: var(--color-border); }
  .tk-blog__category {
    display: inline-block;
    font-family: var(--tk-font-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .tk-blog__featured-title {
    font-family: var(--tk-font-heading);
    font-size: 38px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .tk-blog__featured-excerpt {
    font-family: var(--tk-font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text2);
    margin: 0 0 24px;
  }
  .tk-blog__featured-meta,
  .tk-blog__card-meta {
    font-family: var(--tk-font-body);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0;
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .tk-blog__grid {
    padding: 0 var(--tk-page-x) 80px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 28px;
  }
  .tk-blog__card-link { text-decoration: none; color: inherit; display: block; }
  .tk-blog__card-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    margin-bottom: 16px;
  }
  .tk-blog__card-img--placeholder {
    background: var(--color-border);
  }
  .tk-blog__card-title {
    font-family: var(--tk-font-heading);
    font-size: 22px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 10px;
    line-height: 1.2;
  }
  .tk-blog__card-excerpt {
    font-family: var(--tk-font-body);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-text2);
    margin: 0 0 12px;
  }
  .tk-blog__empty {
    padding: 80px var(--tk-page-x);
    text-align: center;
  }
  .tk-blog__empty-text {
    font-family: var(--tk-font-body);
    font-size: 14px;
    color: var(--color-text2);
  }
  @media (max-width: 900px) {
    .tk-blog__featured-link { grid-template-columns: 1fr; gap: 24px; }
    .tk-blog__featured-img { height: 280px; }
    .tk-blog__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .tk-blog__grid { grid-template-columns: 1fr; }
    .tk-blog__h1 { font-size: 36px; }
    .tk-blog__featured-title { font-size: 28px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Blog Listing",
  "tag": "div",
  "class": "tk-blog-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the Journal" },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Journal" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Design guides, trend reports, and how-tos from our team and the wider Top Knobs community." }
  ]
}
{% endschema %}
