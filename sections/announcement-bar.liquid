{%- if section.blocks.size > 0 -%}
  {%- assign rotate_delay_ms = section.settings.rotate_delay | times: 1000 -%}

  <style>
    #announcement-bar-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      font-family: 'Jost', sans-serif;
      font-size: 12px;
      letter-spacing: 0.08em;
      padding: 9px 20px;
      width: 100%;
    }

    #announcement-bar-{{ section.id }} .tk-ab__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 32px;
    }

    /* CRO batch 2026-05-24: clickable announcement-bar messages.
       Inherit the bar's text colour; subtle underline-on-hover only. */
    #announcement-bar-{{ section.id }} .tk-ab__msg a {
      color: inherit;
      text-decoration: none;
      transition: opacity 0.15s ease;
    }
    #announcement-bar-{{ section.id }} .tk-ab__msg a:hover,
    #announcement-bar-{{ section.id }} .tk-ab__msg a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 3px;
      opacity: 0.9;
      outline: none;
    }

    /* Mobile: hide all messages, show only active one */
    @media (max-width: 767px) {
      #announcement-bar-{{ section.id }} .tk-ab__msg {
        display: none;
      }
      #announcement-bar-{{ section.id }} .tk-ab__msg.is-active {
        display: block;
      }
    }

    /* Fade-in animation for rotating messages */
    @keyframes tk-ab-fade {
      from { opacity: 0; transform: translateY(3px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    #announcement-bar-{{ section.id }} .tk-ab__msg.is-active {
      animation: tk-ab-fade 0.4s ease;
    }
  </style>

  <div id="announcement-bar-{{ section.id }}"
       class="tk-announcement-bar"
       role="region"
       aria-label="Site announcements">
    <div class="tk-ab__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'message' and block.settings.text != blank -%}
          <span class="tk-ab__msg{% if forloop.first %} is-active{% endif %}"
                {{ block.shopify_attributes }}>
            {%- comment -%}
              CRO batch 2026-05-24: wrap in <a> when block.settings.link_url
              is set, so each value prop can be a clickable shortcut to the
              policy/info page that backs the promise. No store-specific
              hardcoded URL fallback on TK — TK's page slugs differ from KC's.
            {%- endcomment -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}">{{ block.settings.text | escape }}</a>
            {%- else -%}
              {{- block.settings.text | escape -}}
            {%- endif -%}
          </span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <script>
    (function () {
      var bar = document.getElementById('announcement-bar-{{ section.id }}');
      if (!bar) return;
      var msgs = Array.prototype.slice.call(bar.querySelectorAll('.tk-ab__msg'));
      if (msgs.length < 2) return;

      var current = 0;

      function isMobile() {
        return window.innerWidth < 768;
      }

      function rotate() {
        if (!isMobile()) return;
        msgs[current].classList.remove('is-active');
        current = (current + 1) % msgs.length;
        msgs[current].classList.add('is-active');
      }

      setInterval(rotate, {{ rotate_delay_ms }});
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "tk-announcement-bar-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0D1526"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F6F7FA"
    },
    {
      "type": "range",
      "id": "rotate_delay",
      "label": "Mobile rotation interval",
      "info": "How long each message shows on mobile before cycling to the next",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message text",
          "default": "✦ Announcement"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL",
          "info": "Optional — link the message to the policy/info page that backs the promise. Leave blank for plain text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
