<!-- ============================================================
  Top Knobs — Collection Section (PATCHED v2)
  Replaces sections/tk-collection.liquid

  CHANGES vs original:
  • Finish-filter values now render colored swatches (uses tk-finish-swatch snippet)
  • Price filter is a styled dual-input range with $ prefixes (visual slider)
  • Active filter chips render above the grid — click to remove
  • Cleaned up filter counts: "Matte Black (1,234)" not "Matte Black 1234"
  • In-stock count formatted with comma separators
  • Sort dropdown moved into a cleaner toolbar
  • Default sort enforced via redirect when ?sort_by= absent (configurable in schema)
============================================================ -->

{%- comment -%}
  Default-sort redirect: when a collection page is loaded without any sort
  in the URL, redirect to the configured default. Runs as early as possible
  to minimise visual flicker. Filters/page params are preserved.
{%- endcomment -%}
<script>
  (function () {
    try {
      var url = new URL(window.location.href);
      if (!url.searchParams.has('sort_by')) {
        url.searchParams.set('sort_by', {{ section.settings.default_sort_by | default: 'price-descending' | json }});
        window.location.replace(url.toString());
      }
    } catch (e) { /* no-op */ }
  })();
</script>

<!-- Breadcrumb -->
<div class="tk-coll__breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span aria-hidden="true">/</span>
  <span class="tk-coll__breadcrumb-current">{{ collection.title | escape }}</span>
</div>

<!-- Collection header -->
<div class="tk-coll__header">
  {%- if collection.image != blank -%}
    {{- collection.image | image_url: width: 2000 | image_tag:
        loading: 'eager', class: 'tk-coll__header-img',
        alt: collection.title | escape -}}
  {%- elsif section.settings.fallback_image != blank -%}
    {{- section.settings.fallback_image | image_url: width: 2000 | image_tag:
        loading: 'eager', class: 'tk-coll__header-img',
        alt: collection.title | escape -}}
  {%- else -%}
    <div class="tk-coll__header-img tk-coll__header-img--placeholder"></div>
  {%- endif -%}
  <div class="tk-coll__header-overlay">
    <h1 class="tk-coll__h1">{{ collection.title | escape }}</h1>
    {%- if collection.description != blank -%}
      <p class="tk-coll__desc">{{ collection.description | strip_html | truncatewords: 20 }}</p>
    {%- endif -%}
  </div>
</div>

<div class="tk-coll__layout">
  <!-- Sidebar filters -->
  <aside class="tk-coll__sidebar" aria-label="Filters">
    {%- if collection.filters.size > 0 -%}
      <form action="{{ collection.url }}" method="get" class="tk-coll__filter-form" id="tk-coll-filter-form">
        {%- for filter in collection.filters -%}
          {%- assign filter_label_lower = filter.label | downcase -%}

          {%- comment -%}
            Skip the Availability filter sitewide. We don't want shoppers to
            self-exclude products by toggling "out of stock" — every product
            in this catalog is in stock by default, and the filter just adds
            visual noise and steals sidebar real estate. To restore: also
            re-enable in Shopify admin → Search & Discovery → Filters.
          {%- endcomment -%}
          {%- if filter_label_lower == 'availability' -%}{%- continue -%}{%- endif -%}

          {%- comment -%}
            Hide filter groups that have no usable values for this collection.
            Example: a "Drill Centers" filter (metafield-based) on a Knobs
            collection — no knob has the metafield, so the filter would
            otherwise render an empty group. We skip when:
              - filter is a list with zero values, OR
              - all of its values have count 0 AND none are currently active
            Price filter is exempt (always relevant).
          {%- endcomment -%}
          {%- if filter.type == 'list' -%}
            {%- comment -%}
              Hide list filters that aren't useful here:
                - 0 usable values (e.g., Drill Centers on a knobs collection)
                - exactly 1 usable value with nothing currently selected
                  (e.g., Collection filter on a single-collection page —
                  the only option matches every product, so it can't narrow)
              Keep filters with 1 value if the user has selected it, so they
              can still untoggle from the sidebar instead of only via the chip.
            {%- endcomment -%}
            {%- assign usable_count = 0 -%}
            {%- assign has_active = false -%}
            {%- for v in filter.values -%}
              {%- if v.count > 0 -%}{%- assign usable_count = usable_count | plus: 1 -%}{%- endif -%}
              {%- if v.active -%}{%- assign has_active = true -%}{%- endif -%}
            {%- endfor -%}
            {%- if usable_count <= 1 and has_active == false -%}{%- continue -%}{%- endif -%}
          {%- endif -%}

          {%- assign is_finish_filter = false -%}
          {%- if filter_label_lower contains 'finish' or filter_label_lower contains 'color' or filter_label_lower contains 'colour' -%}
            {%- assign is_finish_filter = true -%}
          {%- endif -%}

          <details class="tk-coll__filter-group" open>
            <summary class="tk-coll__filter-label">
              <span>{{ filter.label }}</span>
              <span class="tk-coll__filter-chev" aria-hidden="true">+</span>
            </summary>
            <div class="tk-coll__filter-body">
              {%- case filter.type -%}
                {%- when 'list' -%}
                  {%- comment -%}
                    Sort filter values by count descending so the most-populated
                    options surface first. Shopify's default order is whatever the
                    merchant set in Search & Discovery (often alphabetical) — for
                    a long list like "Type" or "Drill Centers", count-desc lands
                    closer to what shoppers actually want to click.
                  {%- endcomment -%}
                  {%- assign sorted_values = filter.values | sort: 'count' | reverse -%}
                  {%- for value in sorted_values -%}
                    {%- comment -%}
                      Clean the displayed label for hierarchical filter values.
                      Shopify renders things like "Cabinet Hardware|Pulls" or
                      "Cabinet Hardware - Knobs" or "Collection: Pemberton".
                      For a customer-facing filter the prefix is noise — just
                      show the leaf segment.
                    {%- endcomment -%}
                    {%- assign display_label = value.label -%}
                    {%- if display_label contains '|' -%}
                      {%- assign display_label = display_label | split: '|' | last | strip -%}
                    {%- elsif display_label contains ' - ' -%}
                      {%- assign display_label = display_label | split: ' - ' | last | strip -%}
                    {%- elsif display_label contains 'Collection: ' -%}
                      {%- assign display_label = display_label | replace: 'Collection: ', '' | strip -%}
                    {%- endif -%}
                    <label class="tk-coll__filter-item{% if is_finish_filter %} tk-coll__filter-item--swatch{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}">
                      <input type="checkbox"
                             name="{{ value.param_name }}"
                             value="{{ value.value }}"
                             {% if value.active %}checked{% endif %}
                             {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                      {%- if is_finish_filter -%}
                        {%- render 'tk-finish-swatch', finish_name: display_label, size: 18, extra_class: 'tk-coll__filter-swatch' -%}
                      {%- endif -%}
                      <span class="tk-coll__filter-text">{{ display_label }}</span>
                      <span class="tk-coll__filter-count">({{ value.count }})</span>
                    </label>
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  {%- comment -%}
                    Shopify unit conventions for the price filter:
                      - filter.range_max and filter.min_value.value are in CENTS
                        (e.g. 20340 = $203.40)
                      - URL params filter.v.price.gte / .lte are in DOLLARS
                        (e.g. 100 = $100 minimum)
                    So we DIVIDE BY 100 for display, and submit the slider's
                    dollar value directly without multiplication.
                  {%- endcomment -%}
                  {%- liquid
                    # filter.range_max / filter.*_value.value are in CENTS.
                    # Split assigns avoid Liquid's filter-chain parsing where
                    # "| default: 50000 | divided_by: 100" treats divided_by
                    # as the default's argument (default = 500), bypassing
                    # the divide on the actual value.
                    assign rmax_cents = filter.range_max | default: 50000
                    assign cmin_cents = filter.min_value.value | default: 0
                    assign cmax_cents = filter.max_value.value
                    if cmax_cents == blank
                      assign cmax_cents = rmax_cents
                    endif
                    assign range_min_dollars = 0
                    assign range_max_dollars = rmax_cents | divided_by: 100
                    assign current_min_dollars = cmin_cents | divided_by: 100
                    assign current_max_dollars = cmax_cents | divided_by: 100
                  -%}
                  <div class="tk-coll__price-slider"
                       data-min="{{ range_min_dollars }}"
                       data-max="{{ range_max_dollars }}"
                       data-min-name="{{ filter.min_value.param_name }}"
                       data-max-name="{{ filter.max_value.param_name }}">
                    <div class="tk-coll__price-display">
                      <span class="tk-coll__price-display-low">${{ current_min_dollars }}</span>
                      <span class="tk-coll__price-display-high">${{ current_max_dollars }}</span>
                    </div>
                    <div class="tk-coll__price-track-wrap">
                      <div class="tk-coll__price-track"></div>
                      <div class="tk-coll__price-fill"></div>
                      <input type="range"
                             class="tk-coll__price-thumb tk-coll__price-thumb--low"
                             min="{{ range_min_dollars }}"
                             max="{{ range_max_dollars }}"
                             value="{{ current_min_dollars }}"
                             step="1"
                             aria-label="Minimum price">
                      <input type="range"
                             class="tk-coll__price-thumb tk-coll__price-thumb--high"
                             min="{{ range_min_dollars }}"
                             max="{{ range_max_dollars }}"
                             value="{{ current_max_dollars }}"
                             step="1"
                             aria-label="Maximum price">
                    </div>
                    <p class="tk-coll__price-range-note">Range: ${{ range_min_dollars }} – ${{ range_max_dollars }}</p>
                    {%- comment -%} Hidden inputs carry the filter values on form submit. Stored in whole dollars (same unit Shopify expects). {%- endcomment -%}
                    <input type="hidden" name="{{ filter.min_value.param_name }}" value="" data-price-min-input>
                    <input type="hidden" name="{{ filter.max_value.param_name }}" value="" data-price-max-input>
                  </div>
              {%- endcase -%}
            </div>
          </details>
        {%- endfor -%}
        <button type="submit" class="tk-btn tk-btn--gold tk-coll__filter-apply">Apply Filters</button>
      </form>
    {%- else -%}
      <p class="tk-coll__filter-label"><span>Filters</span></p>
      <p class="tk-coll__filter-empty">Set up storefront filters in your Shopify admin (Search &amp; Discovery app) to enable filtering.</p>
    {%- endif -%}
  </aside>

  <!-- Products area -->
  <div class="tk-coll__main">
    <div class="tk-coll__toolbar">
      {%- assign formatted_count = collection.products_count -%}
      <p class="tk-coll__count">
        Showing <strong>{{ formatted_count }}</strong> product{% if formatted_count != 1 %}s{% endif %}
      </p>
      <div class="tk-coll__sort">
        <label for="tk-coll-sort">Sort:</label>
        <select id="tk-coll-sort" name="sort_by" class="tk-coll__sort-select">
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>

    {%- comment -%} Active filter chips {%- endcomment -%}
    {%- assign has_active = false -%}
    {%- for filter in collection.filters -%}
      {%- if filter.active_values.size > 0 -%}{%- assign has_active = true -%}{%- endif -%}
      {%- if filter.type == 'price_range' and filter.min_value.value != blank and filter.min_value.value != null -%}{%- assign has_active = true -%}{%- endif -%}
      {%- if filter.type == 'price_range' and filter.max_value.value != blank and filter.max_value.value != null -%}{%- assign has_active = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_active -%}
      <div class="tk-coll__chips">
        {%- for filter in collection.filters -%}
          {%- for active in filter.active_values -%}
            <a href="{{ active.url_to_remove }}" class="tk-coll__chip">
              <span>{{ filter.label }}: {{ active.label }}</span>
              <span class="tk-coll__chip-x" aria-hidden="true">×</span>
            </a>
          {%- endfor -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != blank and filter.min_value.value != null -%}
              <a href="{{ filter.url_to_remove }}" class="tk-coll__chip">
                <span>Min {{ filter.min_value.value | money_without_trailing_zeros }}</span>
                <span class="tk-coll__chip-x" aria-hidden="true">×</span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="tk-coll__chip-clear">Clear all</a>
      </div>
    {%- endif -%}

    {%- comment -%}
      Primary-finish dedup: collection pages should show one card per design
      family (one product per "design root"), not one card per finish-SKU.
      We skip non-primary-finish products in the render loop. We turn the
      dedup OFF when:
        - on a finish-specific collection (handle contains 'finish') —
          everything is already one finish, no dedup needed
        - any filter is active — user wants to see all matches
        - the section setting `apply_primary_filter` is toggled off
    {%- endcomment -%}
    {%- assign apply_dedup = section.settings.apply_primary_filter -%}
    {%- if collection.handle contains 'finish' -%}{%- assign apply_dedup = false -%}{%- endif -%}
    {%- if has_active -%}{%- assign apply_dedup = false -%}{%- endif -%}
    {%- if apply_dedup -%}
      {%- assign per_page = 72 -%}
    {%- else -%}
      {%- assign per_page = 24 -%}
    {%- endif -%}

    {%- paginate collection.products by per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="tk-coll__grid">
          {%- comment -%} Render products with images first, then products without images. Per-page partition keeps the top of every page free of placeholder squares while preserving the merchant's chosen sort order. {%- endcomment -%}
          {%- for product in collection.products -%}
            {%- if apply_dedup -%}
              {%- unless product.tags contains 'primary-finish' -%}{%- continue -%}{%- endunless -%}
            {%- endif -%}
            {%- if product.featured_image -%}
              {%- render 'tk-product-card', product: product -%}
            {%- endif -%}
          {%- endfor -%}
          {%- for product in collection.products -%}
            {%- if apply_dedup -%}
              {%- unless product.tags contains 'primary-finish' -%}{%- continue -%}{%- endunless -%}
            {%- endif -%}
            {%- unless product.featured_image -%}
              {%- render 'tk-product-card', product: product -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="tk-coll__pagination" role="navigation">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="tk-coll__page-btn">&larr; Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="tk-coll__page-btn">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="tk-coll__page-btn tk-coll__page-btn--active">{{ part.title }}</span>
              {%- else -%}
                <span class="tk-coll__page-btn">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="tk-coll__page-btn">Next &rarr;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="tk-coll__empty">
          <p class="tk-coll__empty-h">No products in this collection yet.</p>
          <a href="{{ routes.all_products_collection_url }}" class="tk-btn tk-btn--gold">Browse All Products</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

<!-- SEO copy -->
{%- if section.settings.show_seo -%}
  {%- liquid
    assign coll_desc_text = collection.description | strip_html | strip
    assign coll_title_text = collection.title | strip
    assign has_real_desc = false
    if coll_desc_text != blank and coll_desc_text != coll_title_text and coll_desc_text.size > 60
      assign has_real_desc = true
    endif
  -%}
  <section class="tk-coll__seo">
    <div class="tk-coll__seo-inner">
      {%- if has_real_desc -%}
        <div class="tk-coll__seo-rich rte">{{ collection.description }}</div>
      {%- else -%}
        <h2 class="tk-coll__seo-h2">About {{ collection.title }}</h2>
        <p class="tk-coll__seo-body">Top Knobs is one of America's most respected cabinet hardware brands, offering an unmatched range of knobs, pulls, appliance handles, and bath accessories across more than 40 curated collections. Every piece is crafted from solid zinc alloy and plated to the highest standards, then backed by a lifetime limited warranty.</p>
        <p class="tk-coll__seo-body">As an authorized Top Knobs dealer, TopKnobsHardware.net carries the complete {{ collection.title }} catalog at the lowest prices online — guaranteed. All orders ship within 1–2 business days. Free shipping on orders over $99. Not sure which finish is right for your space? Our <a href="/pages/samples">sample program</a> lets you try hardware in your home before committing to a full order.</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{%- style -%}
  .tk-coll__breadcrumb {
    padding: 16px var(--tk-page-x);
    border-bottom: 1px solid var(--color-border);
    display: flex; gap: 8px; align-items: center;
    font-family: var(--tk-font-body);
    font-size: 12px; color: var(--color-text2);
  }
  .tk-coll__breadcrumb a { color: var(--color-text2); text-decoration: none; }
  .tk-coll__breadcrumb-current { color: var(--color-text); }

  .tk-coll__header { position: relative; height: 240px; overflow: hidden; }
  .tk-coll__header-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tk-coll__header-img--placeholder { background: var(--color-border); }
  .tk-coll__header-overlay {
    position: absolute; inset: 0; background: rgba(13,21,38,0.55);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 0 24px;
  }
  .tk-coll__h1 {
    font-family: var(--tk-font-heading); font-size: 48px; font-weight: 400;
    color: #fff; margin: 0; line-height: 1.05;
  }
  .tk-coll__desc { font-family: var(--tk-font-body); font-size: 14px; color: rgba(255,255,255,0.75); margin: 10px 0 0; max-width: 600px; }

  .tk-coll__layout { display: flex; min-height: 600px; }
  .tk-coll__sidebar { width: 260px; flex-shrink: 0; border-right: 1px solid var(--color-border); padding: 32px 24px; }

  /* Filter group as collapsible details */
  .tk-coll__filter-group {
    margin-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 16px;
  }
  .tk-coll__filter-group:last-of-type { border-bottom: none; }
  .tk-coll__filter-group > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    font-family: var(--tk-font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .tk-coll__filter-group > summary::-webkit-details-marker { display: none; }
  .tk-coll__filter-chev { font-size: 16px; color: var(--color-text2); transition: transform 0.2s ease; line-height: 1; }
  .tk-coll__filter-group[open] .tk-coll__filter-chev { transform: rotate(45deg); }
  .tk-coll__filter-body { padding-top: 4px; }

  .tk-coll__filter-item {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 8px; cursor: pointer;
    font-family: var(--tk-font-body); font-size: 13px; color: var(--color-text);
  }
  .tk-coll__filter-item.is-disabled { opacity: 0.4; cursor: not-allowed; }
  .tk-coll__filter-item input[type="checkbox"] { accent-color: var(--color-accent); margin: 0; flex-shrink: 0; }
  .tk-coll__filter-item--swatch .tk-coll__filter-text { flex: 1; }
  .tk-coll__filter-text { flex: 1; }
  .tk-coll__filter-count { color: var(--color-text2); font-size: 11px; }

  /* Dual-thumb price range slider — replaces the legacy two-number-input price filter. */
  .tk-coll__price-slider { padding: 4px 0 0; }
  .tk-coll__price-display {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 14px;
    font-family: var(--tk-font-body); font-size: 13px;
    color: var(--color-text); font-weight: 500;
  }
  .tk-coll__price-track-wrap {
    position: relative;
    height: 24px;
    margin: 0 9px; /* room for thumbs at both ends so they don't clip the sidebar */
  }
  .tk-coll__price-track {
    position: absolute; top: 11px; left: 0; right: 0;
    height: 2px; background: var(--color-border);
    border-radius: 2px; pointer-events: none;
  }
  .tk-coll__price-fill {
    position: absolute; top: 11px; height: 2px;
    background: var(--color-accent);
    border-radius: 2px; pointer-events: none;
  }
  .tk-coll__price-thumb {
    position: absolute; top: 0; left: -9px; right: -9px; width: calc(100% + 18px);
    margin: 0; padding: 0;
    background: transparent; pointer-events: none;
    -webkit-appearance: none; appearance: none;
    height: 24px; outline: none;
    z-index: 2;
  }
  .tk-coll__price-thumb::-webkit-slider-thumb {
    pointer-events: all;
    -webkit-appearance: none; appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--color-text);
    border: 2px solid var(--color-bg);
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    cursor: grab; transition: transform 0.12s ease;
  }
  .tk-coll__price-thumb::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.1); }
  .tk-coll__price-thumb::-moz-range-thumb {
    pointer-events: all;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--color-text);
    border: 2px solid var(--color-bg);
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    cursor: grab;
  }
  .tk-coll__price-thumb::-webkit-slider-runnable-track,
  .tk-coll__price-thumb::-moz-range-track { background: transparent; border: none; }
  .tk-coll__price-range-note {
    font-family: var(--tk-font-body); font-size: 11px;
    color: var(--color-text2); margin: 12px 0 0;
  }

  .tk-coll__filter-apply {
    width: 100%; margin-top: 16px; text-align: center; cursor: pointer;
    font-size: 11px; padding: 10px;
  }
  .tk-coll__filter-empty {
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-text2); line-height: 1.6; margin: 0;
  }

  .tk-coll__main { flex: 1; padding: 24px 40px; min-width: 0; }
  .tk-coll__toolbar {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 18px; flex-wrap: wrap; gap: 12px;
    padding-bottom: 14px; border-bottom: 1px solid var(--color-border);
  }
  .tk-coll__count { font-family: var(--tk-font-body); font-size: 13px; color: var(--color-text2); margin: 0; }
  .tk-coll__count strong { color: var(--color-text); font-weight: 600; }
  .tk-coll__sort { display: flex; align-items: center; gap: 8px; }
  .tk-coll__sort label { font-family: var(--tk-font-body); font-size: 12px; color: var(--color-text2); }
  .tk-coll__sort-select {
    font-family: var(--tk-font-body); font-size: 13px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text); padding: 6px 12px; outline: none; cursor: pointer;
  }

  /* Active filter chips */
  .tk-coll__chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .tk-coll__chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--color-bg2); border: 1px solid var(--color-border);
    padding: 6px 10px;
    font-family: var(--tk-font-body); font-size: 12px; color: var(--color-text);
    text-decoration: none; transition: border-color 0.2s ease, background 0.2s ease;
  }
  .tk-coll__chip:hover { border-color: var(--color-accent); }
  .tk-coll__chip-x { font-size: 14px; color: var(--color-text2); line-height: 1; }
  .tk-coll__chip-clear {
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-accent); text-decoration: underline;
    align-self: center; margin-left: 4px;
  }

  /* Responsive product grid: cards target ~240–280px wide.
     Wide viewports auto-flow to 4–5 columns; the media queries below
     force tighter counts on narrow viewports. */
  .tk-coll__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 28px; }

  .tk-coll__pagination { display: flex; justify-content: center; gap: 8px; padding: 48px 0 24px; flex-wrap: wrap; }
  .tk-coll__page-btn {
    min-width: 36px; height: 36px; padding: 0 14px;
    border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text);
    font-family: var(--tk-font-body); font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; cursor: pointer;
  }
  .tk-coll__page-btn--active { border-color: var(--color-accent); background: var(--color-accent); color: #fff; }

  .tk-coll__empty { text-align: center; padding: 80px 0; }
  .tk-coll__empty-h { font-family: var(--tk-font-heading); font-size: 24px; color: var(--color-text); margin: 0 0 24px; }

  .tk-coll__seo { padding: 64px var(--tk-page-x); border-top: 1px solid var(--color-border); background: var(--color-bg2); }
  .tk-coll__seo-inner { max-width: 860px; }
  .tk-coll__seo-h2 { font-family: var(--tk-font-heading); font-size: 28px; font-weight: 400; color: var(--color-text); margin: 0 0 16px; }
  .tk-coll__seo-body { font-family: var(--tk-font-body); font-size: 14px; line-height: 1.85; color: var(--color-text2); margin: 0 0 16px; }
  .tk-coll__seo-body a { color: var(--color-accent); text-decoration: underline; }
  .tk-coll__seo-rich { font-family: var(--tk-font-body); font-size: 14px; line-height: 1.85; color: var(--color-text2); }
  .tk-coll__seo-rich h2 { font-family: var(--tk-font-heading); font-size: 28px; font-weight: 400; color: var(--color-text); margin: 32px 0 14px; }
  .tk-coll__seo-rich h2:first-child { margin-top: 0; }
  .tk-coll__seo-rich h3 { font-family: var(--tk-font-heading); font-size: 20px; font-weight: 400; color: var(--color-text); margin: 24px 0 10px; }
  .tk-coll__seo-rich p { margin: 0 0 14px; }
  .tk-coll__seo-rich ul, .tk-coll__seo-rich ol { margin: 0 0 14px; padding-left: 22px; }
  .tk-coll__seo-rich li { margin-bottom: 6px; }
  .tk-coll__seo-rich a { color: var(--color-accent); text-decoration: underline; }
  .tk-coll__seo-rich strong { color: var(--color-text); }
  .tk-coll__seo-rich em { font-style: italic; }

  @media (max-width: 1024px) {
    .tk-coll__main { padding: 24px var(--tk-page-x); }
    .tk-coll__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .tk-coll__layout { flex-direction: column; }
    .tk-coll__sidebar { width: auto; border-right: none; border-bottom: 1px solid var(--color-border); }
    .tk-coll__h1 { font-size: 32px; }
  }
  @media (max-width: 600px) {
    .tk-coll__grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sort = document.getElementById('tk-coll-sort');
    if (sort) {
      sort.addEventListener('change', function () {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', sort.value);
        url.searchParams.delete('page');
        window.location.href = url.toString();
      });
    }

    // Dual-thumb price slider — sync thumbs, update display + fill bar + hidden inputs.
    document.querySelectorAll('.tk-coll__price-slider').forEach(function (slider) {
      var min = parseFloat(slider.dataset.min);
      var max = parseFloat(slider.dataset.max);
      var lowThumb = slider.querySelector('.tk-coll__price-thumb--low');
      var highThumb = slider.querySelector('.tk-coll__price-thumb--high');
      var fill = slider.querySelector('.tk-coll__price-fill');
      var lowDisplay = slider.querySelector('.tk-coll__price-display-low');
      var highDisplay = slider.querySelector('.tk-coll__price-display-high');
      var lowInput = slider.querySelector('[data-price-min-input]');
      var highInput = slider.querySelector('[data-price-max-input]');

      function update(activeThumb) {
        var lo = parseFloat(lowThumb.value);
        var hi = parseFloat(highThumb.value);
        // Prevent thumbs crossing — keep at least 1 unit between them
        if (lo >= hi) {
          if (activeThumb === 'low') { lo = hi - 1; lowThumb.value = lo; }
          else { hi = lo + 1; highThumb.value = hi; }
        }
        var range = max - min;
        var lowPct = range ? ((lo - min) / range) * 100 : 0;
        var highPct = range ? ((hi - min) / range) * 100 : 100;
        fill.style.left = lowPct + '%';
        fill.style.right = (100 - highPct) + '%';
        lowDisplay.textContent = '$' + lo;
        highDisplay.textContent = '$' + hi;
        // Shopify's price filter URL params are in whole dollars (NOT cents).
        // Empty when at min/max so the param is omitted from the URL.
        lowInput.value = lo === min ? '' : Math.round(lo);
        highInput.value = hi === max ? '' : Math.round(hi);
      }

      lowThumb.addEventListener('input', function () { update('low'); });
      highThumb.addEventListener('input', function () { update('high'); });
      update();
    });
  });
</script>

{% schema %}
{
  "name": "Collection",
  "tag": "div",
  "class": "tk-collection-section",
  "settings": [
    { "type": "image_picker", "id": "fallback_image", "label": "Fallback header image (used when collection has no image)" },
    { "type": "checkbox", "id": "show_seo", "label": "Show SEO copy block at bottom", "default": true },
    { "type": "header", "content": "Catalog dedup" },
    {
      "type": "checkbox",
      "id": "apply_primary_filter",
      "label": "Show only one product per design family",
      "info": "Hides duplicate finish-SKUs of the same design on collection pages. Auto-disabled on finish-specific collections (e.g. /collections/honey-bronze-finish) and whenever a filter is active. Requires products to be tagged `primary-finish` — see scripts/tag-primary-finishes.py.",
      "default": true
    },
    { "type": "header", "content": "Default sort" },
    {
      "type": "select",
      "id": "default_sort_by",
      "label": "Default sort order",
      "info": "Applied when shoppers land on a collection page without a sort already in the URL. They can still change it via the dropdown.",
      "options": [
        { "value": "price-descending", "label": "Price: High to Low" },
        { "value": "best-selling", "label": "Best selling" },
        { "value": "manual", "label": "Featured (manual order)" },
        { "value": "created-descending", "label": "Newest first" },
        { "value": "price-ascending", "label": "Price: Low to High" },
        { "value": "title-ascending", "label": "Alphabetical: A–Z" },
        { "value": "title-descending", "label": "Alphabetical: Z–A" }
      ],
      "default": "price-descending"
    }
  ]
}
{% endschema %}
