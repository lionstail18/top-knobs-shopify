<section class="tk-sample-cta">
  <div class="tk-sample-cta__text">
    {%- if section.settings.eyebrow != blank -%}
      <p class="tk-eyebrow tk-sample-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="tk-sample-cta__h2">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="tk-sample-cta__body">{{ section.settings.body | escape }}</p>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url | default: routes.all_products_collection_url }}"
         class="tk-btn tk-btn--gold">
        {{- section.settings.btn_label | escape -}}
      </a>
    {%- endif -%}
  </div>

  <div class="tk-sample-cta__media">
    {%- if section.settings.image != blank -%}
      {{- section.settings.image | image_url: width: 800 | image_tag:
          loading: 'lazy',
          class: 'tk-sample-cta__img',
          alt: section.settings.heading | escape -}}
    {%- else -%}
      <div class="tk-sample-cta__img tk-sample-cta__img--placeholder"></div>
    {%- endif -%}
  </div>
</section>

{%- style -%}
  .tk-sample-cta {
    background: var(--color-nav-bg);
    padding: var(--tk-section-y) var(--tk-page-x);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .tk-sample-cta__eyebrow { margin: 0 0 12px; }
  .tk-sample-cta__h2 {
    font-family: var(--tk-font-heading);
    font-size: 44px;
    font-weight: 400;
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .tk-sample-cta__body {
    font-family: var(--tk-font-body);
    font-size: 14px;
    line-height: 1.75;
    color: rgba(255,255,255,0.65);
    margin: 0 0 32px;
  }
  .tk-sample-cta__img {
    display: block;
    width: 100%;
    height: 380px;
    object-fit: cover;
  }
  .tk-sample-cta__img--placeholder {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
  }
  @media (max-width: 768px) {
    .tk-sample-cta {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .tk-sample-cta__h2 { font-size: 36px; }
    .tk-sample-cta__media { order: -1; }
    .tk-sample-cta__img { height: 260px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Sample CTA",
  "tag": "div",
  "class": "tk-sample-cta-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Before You Commit"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Try Before<br>You Buy"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Unsure which finish is right for your space? Order samples and see them in your home. We'll refund the cost of samples you don't choose toward your final order."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Learn About Our Sample Program"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    }
  ],
  "presets": [
    { "name": "Sample CTA" }
  ]
}
{% endschema %}
