{
  "name": "Search With Filters",
  "tag": "div",
  "class": "tk-search-with-filters-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text (pre-search hero)",
      "default": "Search Our Catalog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (pre-search hero)",
      "default": "Find Your Perfect Hardware"
    },
    {
      "type": "text",
      "id": "suggestions",
      "label": "Popular search suggestions (comma-separated)",
      "default": "Honey Bronze Knobs, Bar Pulls, Pemberton Collection, Brushed Nickel Pulls, Appliance Pulls, Serene Collection",
      "info": "Shown as quick-link chips on the pre-search hero. Comma-separated."
    }
  ]
}
{% endschema %}
