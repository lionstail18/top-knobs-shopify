<!-- ============================================================
  Top Knobs — Search With Filters Section
  Ports tk-collection.liquid's filter sidebar, toolbar, chips,
  product grid, and pagination to /search using search.* objects
  instead of collection.*.

  Notable differences vs tk-collection:
  • No breadcrumb (search isn't a hierarchical entity)
  • No collection.image hero — compact centered header instead
  • Pre-search empty state (visiting /search without ?q=) renders
    a hero with refinement input + popular suggestions, mirroring
    the original tk-search.liquid section
  • No primary-finish dedup (not relevant for search)
  • No SEO copy block at the bottom
  • Default sort = Shopify's relevance (no redirect)
  • Filter form preserves q + type=product as hidden inputs so
    submitting filters keeps the search context
============================================================ -->

{%- if search.performed and search.terms != blank -%}

  <!-- Compact header (search performed) -->
  <div class="tk-srch__header">
    <div class="tk-srch__header-inner">
      <p class="tk-eyebrow">Search Results</p>
      <h1 class="tk-srch__h1">&ldquo;{{ search.terms | escape }}&rdquo;</h1>
      <form class="tk-srch__refine-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input class="tk-srch__refine-input"
               name="q"
               type="search"
               value="{{ search.terms | escape }}"
               placeholder="Refine your search&hellip;"
               autocomplete="off">
        <button type="submit" class="tk-srch__refine-submit">Search</button>
      </form>
    </div>
  </div>

  <div class="tk-srch__layout">

    <!-- Sidebar filters -->
    <aside class="tk-srch__sidebar" aria-label="Filters">
      {%- if search.filters.size > 0 -%}
        <form action="{{ routes.search_url }}" method="get" class="tk-srch__filter-form" id="tk-srch-filter-form">
          {%- comment -%} Preserve search context across filter submit {%- endcomment -%}
          <input type="hidden" name="q" value="{{ search.terms | escape }}">
          <input type="hidden" name="type" value="product">

          {%- for filter in search.filters -%}
            {%- assign filter_label_lower = filter.label | downcase -%}

            {%- comment -%} Skip Availability sitewide (every product is in stock by default). {%- endcomment -%}
            {%- if filter_label_lower == 'availability' -%}{%- continue -%}{%- endif -%}

            {%- comment -%}
              Hide list filters that aren't useful here:
                - 0 usable values
                - exactly 1 usable value with nothing currently selected
              Price filter is exempt (always relevant).
            {%- endcomment -%}
            {%- if filter.type == 'list' -%}
              {%- assign usable_count = 0 -%}
              {%- assign has_active = false -%}
              {%- for v in filter.values -%}
                {%- if v.count > 0 -%}{%- assign usable_count = usable_count | plus: 1 -%}{%- endif -%}
                {%- if v.active -%}{%- assign has_active = true -%}{%- endif -%}
              {%- endfor -%}
              {%- if usable_count <= 1 and has_active == false -%}{%- continue -%}{%- endif -%}
            {%- endif -%}

            {%- assign is_finish_filter = false -%}
            {%- if filter_label_lower contains 'finish' or filter_label_lower contains 'color' or filter_label_lower contains 'colour' -%}
              {%- assign is_finish_filter = true -%}
            {%- endif -%}

            <details class="tk-srch__filter-group" open>
              <summary class="tk-srch__filter-label">
                <span>{{ filter.label }}</span>
                <span class="tk-srch__filter-chev" aria-hidden="true">+</span>
              </summary>
              <div class="tk-srch__filter-body">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    {%- assign sorted_values = filter.values | sort: 'count' | reverse -%}
                    {%- assign overflow_threshold = 6 -%}
                    {%- assign overflow_size = sorted_values.size | minus: overflow_threshold -%}
                    {%- if overflow_size < 0 -%}{%- assign overflow_size = 0 -%}{%- endif -%}
                    {%- for value in sorted_values -%}
                      {%- assign display_label = value.label -%}
                      {%- if display_label contains '|' -%}
                        {%- assign display_label = display_label | split: '|' | last | strip -%}
                      {%- elsif display_label contains ' - ' -%}
                        {%- assign display_label = display_label | split: ' - ' | last | strip -%}
                      {%- elsif display_label contains 'Collection: ' -%}
                        {%- assign display_label = display_label | replace: 'Collection: ', '' | strip -%}
                      {%- endif -%}
                      <label class="tk-srch__filter-item{% if is_finish_filter %} tk-srch__filter-item--swatch{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}{% if value.active %} is-active{% endif %}">
                        <input type="checkbox"
                               name="{{ value.param_name }}"
                               value="{{ value.value }}"
                               {% if value.active %}checked{% endif %}
                               {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                        {%- if is_finish_filter -%}
                          {%- render 'tk-finish-swatch', finish_name: display_label, size: 18, extra_class: 'tk-srch__filter-swatch' -%}
                        {%- endif -%}
                        <span class="tk-srch__filter-text">{{ display_label }}</span>
                        <span class="tk-srch__filter-count">({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                    {%- if overflow_size > 0 -%}
                      <button type="button"
                              class="tk-srch__filter-more"
                              data-more-count="{{ overflow_size }}"
                              data-more-label="See {{ overflow_size }} more"
                              data-less-label="See less">See {{ overflow_size }} more</button>
                    {%- endif -%}
                  {%- when 'price_range' -%}
                    {%- liquid
                      assign rmax_cents = filter.range_max | default: 50000
                      assign cmin_cents = filter.min_value.value | default: 0
                      assign cmax_cents = filter.max_value.value
                      if cmax_cents == blank
                        assign cmax_cents = rmax_cents
                      endif
                      assign range_min_dollars = 0
                      assign range_max_dollars = rmax_cents | divided_by: 100
                      assign current_min_dollars = cmin_cents | divided_by: 100
                      assign current_max_dollars = cmax_cents | divided_by: 100
                    -%}
                    <div class="tk-srch__price-slider"
                         data-min="{{ range_min_dollars }}"
                         data-max="{{ range_max_dollars }}"
                         data-min-name="{{ filter.min_value.param_name }}"
                         data-max-name="{{ filter.max_value.param_name }}">
                      <div class="tk-srch__price-display">
                        <span class="tk-srch__price-display-low">${{ current_min_dollars }}</span>
                        <span class="tk-srch__price-display-high">${{ current_max_dollars }}</span>
                      </div>
                      <div class="tk-srch__price-track-wrap">
                        <div class="tk-srch__price-track"></div>
                        <div class="tk-srch__price-fill"></div>
                        <input type="range"
                               class="tk-srch__price-thumb tk-srch__price-thumb--low"
                               min="{{ range_min_dollars }}"
                               max="{{ range_max_dollars }}"
                               value="{{ current_min_dollars }}"
                               step="1"
                               aria-label="Minimum price">
                        <input type="range"
                               class="tk-srch__price-thumb tk-srch__price-thumb--high"
                               min="{{ range_min_dollars }}"
                               max="{{ range_max_dollars }}"
                               value="{{ current_max_dollars }}"
                               step="1"
                               aria-label="Maximum price">
                      </div>
                      <p class="tk-srch__price-range-note">Range: ${{ range_min_dollars }} &ndash; ${{ range_max_dollars }}</p>
                      <input type="hidden" name="{{ filter.min_value.param_name }}" value="" data-price-min-input>
                      <input type="hidden" name="{{ filter.max_value.param_name }}" value="" data-price-max-input>
                    </div>
                {%- endcase -%}
              </div>
            </details>
          {%- endfor -%}
          <button type="submit" class="tk-btn tk-btn--gold tk-srch__filter-apply">Apply Filters</button>
        </form>
      {%- else -%}
        <p class="tk-srch__filter-label"><span>Filters</span></p>
        <p class="tk-srch__filter-empty">Set up storefront filters in your Shopify admin (Search &amp; Discovery app) to enable filtering on search results.</p>
      {%- endif -%}
    </aside>

    <!-- Results area -->
    <div class="tk-srch__main">
      <div class="tk-srch__toolbar">
        <p class="tk-srch__count">
          Showing <strong>{{ search.results_count }}</strong> result{% if search.results_count != 1 %}s{% endif %} for &ldquo;{{ search.terms | escape }}&rdquo;
        </p>
        <div class="tk-srch__sort">
          <label for="tk-srch-sort">Sort:</label>
          <select id="tk-srch-sort" name="sort_by" class="tk-srch__sort-select">
            {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
            {%- for option in search.sort_options -%}
              <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name }}</option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      {%- comment -%} Active filter chips {%- endcomment -%}
      {%- assign has_any_active = false -%}
      {%- for filter in search.filters -%}
        {%- if filter.active_values.size > 0 -%}{%- assign has_any_active = true -%}{%- endif -%}
        {%- if filter.type == 'price_range' and filter.min_value.value != blank and filter.min_value.value != null -%}{%- assign has_any_active = true -%}{%- endif -%}
        {%- if filter.type == 'price_range' and filter.max_value.value != blank and filter.max_value.value != null -%}{%- assign has_any_active = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_any_active -%}
        {%- capture clear_url -%}{{ routes.search_url }}?q={{ search.terms | url_encode }}&type=product{%- endcapture -%}
        <div class="tk-srch__chips">
          {%- for filter in search.filters -%}
            {%- for active in filter.active_values -%}
              <a href="{{ active.url_to_remove }}" class="tk-srch__chip">
                <span>{{ filter.label }}: {{ active.label }}</span>
                <span class="tk-srch__chip-x" aria-hidden="true">&times;</span>
              </a>
            {%- endfor -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank and filter.min_value.value != null -%}
                <a href="{{ filter.url_to_remove }}" class="tk-srch__chip">
                  <span>Min {{ filter.min_value.value | money_without_trailing_zeros }}</span>
                  <span class="tk-srch__chip-x" aria-hidden="true">&times;</span>
                </a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <a href="{{ clear_url }}" class="tk-srch__chip-clear">Clear all</a>
        </div>
      {%- endif -%}

      {%- paginate search.results by 24 -%}
        {%- if search.results.size > 0 -%}
          <div class="tk-srch__grid">
            {%- comment -%} Products with images first, then without — same partition trick as tk-collection. {%- endcomment -%}
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' and item.featured_image -%}
                {%- render 'tk-product-card', product: item -%}
              {%- endif -%}
            {%- endfor -%}
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' and item.featured_image == blank -%}
                {%- render 'tk-product-card', product: item -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="tk-srch__pagination" role="navigation">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="tk-srch__page-btn">&larr; Previous</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="tk-srch__page-btn">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="tk-srch__page-btn tk-srch__page-btn--active">{{ part.title }}</span>
                {%- else -%}
                  <span class="tk-srch__page-btn">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="tk-srch__page-btn">Next &rarr;</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <div class="tk-srch__empty">
            <h2 class="tk-srch__empty-h2">No results found{% if search.terms != blank %} for &ldquo;{{ search.terms | escape }}&rdquo;{% endif %}</h2>
            <p class="tk-srch__empty-sub">Try a different search term, or browse by category below.</p>
            <div class="tk-srch__empty-btns">
              <a href="{{ routes.all_products_collection_url }}" class="tk-btn tk-btn--gold">Browse All Products</a>
              <a href="/pages/contact" class="tk-btn tk-btn--ghost-border">Ask for Help</a>
            </div>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>

{%- else -%}

  <!-- Pre-search hero (visiting /search without ?q=) -->
  <div class="tk-srch__hero">
    <div class="tk-srch__hero-inner">
      <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1 class="tk-srch__hero-h1">{{ section.settings.heading | escape }}</h1>
      <form class="tk-srch__hero-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input
          class="tk-srch__hero-input"
          name="q"
          type="search"
          placeholder="Search by name, collection, finish, or SKU&hellip;"
          autocomplete="off"
          autofocus>
        <button type="submit" class="tk-srch__hero-submit">Search</button>
      </form>
      {%- if section.settings.suggestions != blank -%}
        <div class="tk-srch__hero-suggestions">
          <span class="tk-srch__hero-suggestions-label">Popular:</span>
          {%- assign suggestions = section.settings.suggestions | split: ',' -%}
          {%- for s in suggestions -%}
            <a class="tk-srch__hero-suggestion" href="{{ routes.search_url }}?q={{ s | strip | url_encode }}&type=product">{{ s | strip }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

{%- endif -%}

{%- style -%}
  /* ─── Compact post-search header ─── */
  .tk-srch__header {
    padding: 40px var(--tk-page-x) 28px;
    background: var(--color-bg2);
    border-bottom: 1px solid var(--color-border);
  }
  .tk-srch__header-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .tk-srch__header .tk-eyebrow { margin: 0 0 10px; }
  .tk-srch__h1 {
    font-family: var(--tk-font-heading);
    font-size: 36px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .tk-srch__refine-form {
    display: flex; gap: 0; max-width: 520px; margin: 0 auto;
  }
  .tk-srch__refine-input {
    flex: 1;
    height: 44px;
    padding: 0 14px;
    font-family: var(--tk-font-body); font-size: 14px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text); outline: none; border-radius: 0;
  }
  .tk-srch__refine-input:focus { border-color: var(--color-accent); }
  .tk-srch__refine-submit {
    height: 44px; padding: 0 20px;
    background: var(--color-accent); color: #fff;
    font-family: var(--tk-font-body); font-size: 11px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    border: 1px solid var(--color-accent); cursor: pointer;
  }
  .tk-srch__refine-submit:hover { background: var(--color-text); border-color: var(--color-text); }

  /* ─── Layout ─── */
  .tk-srch__layout { display: flex; min-height: 600px; }
  .tk-srch__sidebar {
    width: 260px; flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    padding: 32px 24px;
  }

  /* ─── Filter group ─── */
  .tk-srch__filter-group {
    margin-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 16px;
  }
  .tk-srch__filter-group:last-of-type { border-bottom: none; }
  .tk-srch__filter-group > summary {
    list-style: none; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 0;
    font-family: var(--tk-font-body);
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-text);
  }
  .tk-srch__filter-group > summary::-webkit-details-marker { display: none; }
  .tk-srch__filter-chev { font-size: 16px; color: var(--color-text2); transition: transform 0.2s ease; line-height: 1; }
  .tk-srch__filter-group[open] .tk-srch__filter-chev { transform: rotate(45deg); }
  .tk-srch__filter-body { padding-top: 4px; }

  .tk-srch__filter-item {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 8px; cursor: pointer;
    font-family: var(--tk-font-body); font-size: 13px; color: var(--color-text);
  }
  .tk-srch__filter-item.is-disabled { opacity: 0.4; cursor: not-allowed; }
  .tk-srch__filter-item input[type="checkbox"] { accent-color: var(--color-accent); margin: 0; flex-shrink: 0; }
  .tk-srch__filter-item--swatch .tk-srch__filter-text { flex: 1; }
  .tk-srch__filter-text { flex: 1; }
  .tk-srch__filter-count { color: var(--color-text2); font-size: 11px; }

  .tk-srch__filter-body > .tk-srch__filter-item:nth-of-type(n+7) { display: none; }
  .tk-srch__filter-body > .tk-srch__filter-item.is-active { display: flex; }
  .tk-srch__filter-body.is-expanded > .tk-srch__filter-item { display: flex; }
  .tk-srch__filter-more {
    background: none; border: none;
    padding: 8px 0 0; cursor: pointer;
    font-family: var(--tk-font-body);
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-accent); text-align: left; width: 100%;
  }
  .tk-srch__filter-more:hover { text-decoration: underline; }

  /* ─── Price range slider ─── */
  .tk-srch__price-slider { padding: 4px 0 0; }
  .tk-srch__price-display {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 14px;
    font-family: var(--tk-font-body); font-size: 13px;
    color: var(--color-text); font-weight: 500;
  }
  .tk-srch__price-track-wrap {
    position: relative; height: 24px; margin: 0 9px;
  }
  .tk-srch__price-track {
    position: absolute; top: 11px; left: 0; right: 0;
    height: 2px; background: var(--color-border);
    border-radius: 2px; pointer-events: none;
  }
  .tk-srch__price-fill {
    position: absolute; top: 11px; height: 2px;
    background: var(--color-accent);
    border-radius: 2px; pointer-events: none;
  }
  .tk-srch__price-thumb {
    position: absolute; top: 0; left: -9px; right: -9px; width: calc(100% + 18px);
    margin: 0; padding: 0; background: transparent; pointer-events: none;
    -webkit-appearance: none; appearance: none;
    height: 24px; outline: none; z-index: 2;
  }
  .tk-srch__price-thumb::-webkit-slider-thumb {
    pointer-events: all;
    -webkit-appearance: none; appearance: none;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--color-text); border: 2px solid var(--color-bg);
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    cursor: grab; transition: transform 0.12s ease;
  }
  .tk-srch__price-thumb::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.1); }
  .tk-srch__price-thumb::-moz-range-thumb {
    pointer-events: all;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--color-text); border: 2px solid var(--color-bg);
    box-shadow: 0 1px 4px rgba(0,0,0,0.18); cursor: grab;
  }
  .tk-srch__price-thumb::-webkit-slider-runnable-track,
  .tk-srch__price-thumb::-moz-range-track { background: transparent; border: none; }
  .tk-srch__price-range-note {
    font-family: var(--tk-font-body); font-size: 11px;
    color: var(--color-text2); margin: 12px 0 0;
  }

  .tk-srch__filter-apply {
    width: 100%; margin-top: 16px; text-align: center; cursor: pointer;
    font-size: 11px; padding: 10px;
  }
  .tk-srch__filter-empty {
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-text2); line-height: 1.6; margin: 0;
  }

  /* ─── Main results area ─── */
  .tk-srch__main { flex: 1; padding: 24px 40px; min-width: 0; transition: opacity 0.15s ease; }
  .tk-srch__main.is-loading { opacity: 0.45; pointer-events: none; }

  /* When live filtering is active (JS enabled), hide the Apply Filters button —
     filters now apply on every checkbox change. The button still works as a
     no-JS fallback. */
  .tk-srch__filter-form[data-live-enabled="true"] .tk-srch__filter-apply { display: none; }
  .tk-srch__toolbar {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 18px; flex-wrap: wrap; gap: 12px;
    padding-bottom: 14px; border-bottom: 1px solid var(--color-border);
  }
  .tk-srch__count {
    font-family: var(--tk-font-body); font-size: 13px;
    color: var(--color-text2); margin: 0;
  }
  .tk-srch__count strong { color: var(--color-text); font-weight: 600; }
  .tk-srch__sort { display: flex; align-items: center; gap: 8px; }
  .tk-srch__sort label {
    font-family: var(--tk-font-body); font-size: 12px; color: var(--color-text2);
  }
  .tk-srch__sort-select {
    font-family: var(--tk-font-body); font-size: 13px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text); padding: 6px 12px; outline: none; cursor: pointer;
  }

  /* ─── Active chips ─── */
  .tk-srch__chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .tk-srch__chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--color-bg2); border: 1px solid var(--color-border);
    padding: 6px 10px;
    font-family: var(--tk-font-body); font-size: 12px; color: var(--color-text);
    text-decoration: none; transition: border-color 0.2s ease, background 0.2s ease;
  }
  .tk-srch__chip:hover { border-color: var(--color-accent); }
  .tk-srch__chip-x { font-size: 14px; color: var(--color-text2); line-height: 1; }
  .tk-srch__chip-clear {
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-accent); text-decoration: underline;
    align-self: center; margin-left: 4px;
  }

  /* ─── Grid ─── */
  .tk-srch__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 28px;
  }

  /* tk-pcard helpers — mirror of the inline styles in snippets/tk-product-card.liquid.
     We duplicate them here (the surrounding style block is hoisted to head) so they
     persist when tk-algolia-search.js replaces the grid contents. The inline snippet
     block lives INSIDE the grid and would otherwise be removed during that DOM swap. */
  .tk-pcard__media { position: relative; }
  .tk-pcard__sale-badge {
    position: absolute; top: 10px; left: 10px; z-index: 2;
    background: oklch(50% 0.13 145); color: #fff;
    font-family: var(--tk-font-body); font-size: 10px;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 4px 8px;
  }
  .tk-pcard__price-wrap { display: flex; align-items: baseline; gap: 8px; }
  .tk-pcard__price-was {
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-text2); text-decoration: line-through;
  }

  /* ─── Pagination ─── */
  .tk-srch__pagination { display: flex; justify-content: center; gap: 8px; padding: 48px 0 24px; flex-wrap: wrap; }
  .tk-srch__page-btn {
    min-width: 36px; height: 36px; padding: 0 14px;
    border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text);
    font-family: var(--tk-font-body); font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; cursor: pointer;
  }
  .tk-srch__page-btn--active { border-color: var(--color-accent); background: var(--color-accent); color: #fff; }

  /* ─── Empty state ─── */
  .tk-srch__empty { text-align: center; padding: 80px 24px; }
  .tk-srch__empty-h2 {
    font-family: var(--tk-font-heading); font-size: 28px; font-weight: 400;
    color: var(--color-text); margin: 0 0 12px;
  }
  .tk-srch__empty-sub {
    font-family: var(--tk-font-body); font-size: 14px;
    color: var(--color-text2); margin: 0 0 24px;
  }
  .tk-srch__empty-btns {
    display: inline-flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  }

  /* ─── Pre-search hero ─── */
  .tk-srch__hero {
    padding: 80px var(--tk-page-x) 64px;
    background: var(--color-bg2);
    border-bottom: 1px solid var(--color-border);
  }
  .tk-srch__hero-inner {
    max-width: 640px; margin: 0 auto; text-align: center;
  }
  .tk-srch__hero .tk-eyebrow { margin: 0 0 12px; }
  .tk-srch__hero-h1 {
    font-family: var(--tk-font-heading);
    font-size: 44px; font-weight: 400;
    color: var(--color-text);
    margin: 0 0 28px; line-height: 1.05;
  }
  .tk-srch__hero-form {
    display: flex; gap: 0; max-width: 520px; margin: 0 auto 24px;
  }
  .tk-srch__hero-input {
    flex: 1; height: 48px; padding: 0 16px;
    font-family: var(--tk-font-body); font-size: 14px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text); outline: none; border-radius: 0;
  }
  .tk-srch__hero-input:focus { border-color: var(--color-accent); }
  .tk-srch__hero-submit {
    height: 48px; padding: 0 28px;
    background: var(--color-accent); color: #fff;
    font-family: var(--tk-font-body); font-size: 11px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    border: 1px solid var(--color-accent); cursor: pointer;
  }
  .tk-srch__hero-submit:hover { background: var(--color-text); border-color: var(--color-text); }
  .tk-srch__hero-suggestions {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 8px 12px; align-items: center;
    font-family: var(--tk-font-body); font-size: 12px;
    color: var(--color-text2);
  }
  .tk-srch__hero-suggestions-label {
    text-transform: uppercase; letter-spacing: 0.12em;
    font-weight: 600; font-size: 11px;
  }
  .tk-srch__hero-suggestion {
    color: var(--color-text); text-decoration: none;
    border-bottom: 1px solid transparent; padding-bottom: 1px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .tk-srch__hero-suggestion:hover {
    color: var(--color-accent); border-bottom-color: var(--color-accent);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .tk-srch__main { padding: 24px var(--tk-page-x); }
    .tk-srch__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .tk-srch__layout { flex-direction: column; }
    .tk-srch__sidebar {
      width: auto; border-right: none; border-bottom: 1px solid var(--color-border);
    }
    .tk-srch__h1 { font-size: 28px; }
    .tk-srch__hero-h1 { font-size: 32px; }
  }
  @media (max-width: 600px) {
    .tk-srch__grid { grid-template-columns: 1fr; }
    .tk-srch__refine-form, .tk-srch__hero-form { flex-direction: column; }
    .tk-srch__refine-submit, .tk-srch__hero-submit { width: 100%; }
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Skip if tk-live-filter.js already handles live updates (it manages
    // sort, filter-more, and price slider via its own delegation/reinit).
    if (window.tkLiveFilterLoaded) return;

    // Sort dropdown — preserve q and other URL params; reset page.
    var sort = document.getElementById('tk-srch-sort');
    if (sort) {
      sort.addEventListener('change', function () {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', sort.value);
        url.searchParams.delete('page');
        window.location.href = url.toString();
      });
    }

    // Filter "See more" toggle
    document.querySelectorAll('.tk-srch__filter-more').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var body = btn.closest('.tk-srch__filter-body');
        if (!body) return;
        var expanded = body.classList.toggle('is-expanded');
        btn.textContent = expanded ? btn.dataset.lessLabel : btn.dataset.moreLabel;
      });
    });

    // Dual-thumb price slider
    document.querySelectorAll('.tk-srch__price-slider').forEach(function (slider) {
      var min = parseFloat(slider.dataset.min);
      var max = parseFloat(slider.dataset.max);
      var lowThumb = slider.querySelector('.tk-srch__price-thumb--low');
      var highThumb = slider.querySelector('.tk-srch__price-thumb--high');
      var fill = slider.querySelector('.tk-srch__price-fill');
      var lowDisplay = slider.querySelector('.tk-srch__price-display-low');
      var highDisplay = slider.querySelector('.tk-srch__price-display-high');
      var lowInput = slider.querySelector('[data-price-min-input]');
      var highInput = slider.querySelector('[data-price-max-input]');

      function update(activeThumb) {
        var lo = parseFloat(lowThumb.value);
        var hi = parseFloat(highThumb.value);
        if (lo >= hi) {
          if (activeThumb === 'low') { lo = hi - 1; lowThumb.value = lo; }
          else { hi = lo + 1; highThumb.value = hi; }
        }
        var range = max - min;
        var lowPct = range ? ((lo - min) / range) * 100 : 0;
        var highPct = range ? ((hi - min) / range) * 100 : 100;
        fill.style.left = lowPct + '%';
        fill.style.right = (100 - highPct) + '%';
        lowDisplay.textContent = '$' + lo;
        highDisplay.textContent = '$' + hi;
        lowInput.value = lo === min ? '' : Math.round(lo);
        highInput.value = hi === max ? '' : Math.round(hi);
      }

      lowThumb.addEventListener('input', function () { update('low'); });
      highThumb.addEventListener('input', function () { update('high'); });
      update();
    });
  });
</script>

