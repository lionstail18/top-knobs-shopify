<!-- Search header -->
<div class="tk-search__header">
  <div class="tk-search__header-inner">
    <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1 class="tk-search__h1">{{ section.settings.heading | escape }}</h1>
    <form class="tk-search__form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input
        class="tk-search__input"
        name="q"
        type="search"
        placeholder="Search by name, collection, finish, or SKU…"
        value="{{ search.terms | escape }}"
        autocomplete="off"
        autofocus>
      <button type="submit" class="tk-search__submit">Search</button>
    </form>
    {%- unless search.performed -%}
      <div class="tk-search__suggestions">
        <span class="tk-search__suggestions-label">Popular:</span>
        {%- assign suggestions = section.settings.suggestions | split: ',' -%}
        {%- for s in suggestions -%}
          <a class="tk-search__suggestion" href="{{ routes.search_url }}?q={{ s | strip | url_encode }}&type=product">{{ s | strip }}</a>
        {%- endfor -%}
      </div>
    {%- endunless -%}
  </div>
</div>

<!-- Results -->
<div class="tk-search__results">
  {%- if search.performed -%}
    <p class="tk-search__count">
      {%- if search.results_count > 0 -%}
        {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms | escape }}"
      {%- else -%}
        No results found for "{{ search.terms | escape }}"
      {%- endif -%}
    </p>

    {%- if search.results_count > 0 -%}
      <div class="tk-search__grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'tk-product-card', product: item -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="tk-search__pagination" role="navigation">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="tk-search__page-btn">&larr; Previous</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="tk-search__page-btn">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="tk-search__page-btn tk-search__page-btn--active">{{ part.title }}</span>
            {%- else -%}
              <span class="tk-search__page-btn">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="tk-search__page-btn">Next &rarr;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- else -%}
      <div class="tk-search__empty">
        <h2 class="tk-search__empty-h2">No Results Found</h2>
        <p class="tk-search__empty-sub">Try a different search term, or browse by category below.</p>
        <div class="tk-search__empty-btns">
          <a href="{{ routes.all_products_collection_url }}" class="tk-btn tk-btn--gold">Browse All Products</a>
          <a href="/pages/contact" class="tk-btn tk-btn--ghost-border">Ask for Help</a>
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{%- style -%}
  .tk-search__header {
    padding: 56px var(--tk-page-x) 40px;
    background: var(--color-bg2);
    border-bottom: 1px solid var(--color-border);
  }
  .tk-search__header-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .tk-search__header .tk-eyebrow { margin: 0 0 12px; }
  .tk-search__h1 {
    font-family: var(--tk-font-heading);
    font-size: 44px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 24px;
    line-height: 1.05;
  }
  .tk-search__form {
    display: flex;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .tk-search__input {
    flex: 1;
    padding: 14px 16px;
    border: none;
    background: none;
    font-family: var(--tk-font-body);
    font-size: 14px;
    color: var(--color-text);
    outline: none;
  }
  .tk-search__submit {
    padding: 0 24px;
    background: var(--color-accent);
    border: none;
    color: #fff;
    font-family: var(--tk-font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .tk-search__suggestions {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    align-items: center;
  }
  .tk-search__suggestions-label {
    font-family: var(--tk-font-body);
    font-size: 11px;
    color: var(--color-text2);
  }
  .tk-search__suggestion {
    font-family: var(--tk-font-body);
    font-size: 11px;
    color: var(--color-accent);
    text-decoration: underline;
  }
  .tk-search__results {
    padding: 40px var(--tk-page-x) 80px;
  }
  .tk-search__count {
    font-family: var(--tk-font-body);
    font-size: 13px;
    color: var(--color-text2);
    margin: 0 0 28px;
  }
  .tk-search__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .tk-search__pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 48px 0 24px;
    flex-wrap: wrap;
  }
  .tk-search__page-btn {
    min-width: 36px;
    height: 36px;
    padding: 0 14px;
    border: 1px solid var(--color-border);
    background: none;
    color: var(--color-text);
    font-family: var(--tk-font-body);
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .tk-search__page-btn--active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #fff;
  }
  .tk-search__empty {
    text-align: center;
    padding: 60px 0;
  }
  .tk-search__empty-h2 {
    font-family: var(--tk-font-heading);
    font-size: 32px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 12px;
  }
  .tk-search__empty-sub {
    font-family: var(--tk-font-body);
    font-size: 14px;
    color: var(--color-text2);
    margin: 0 0 32px;
  }
  .tk-search__empty-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 900px) {
    .tk-search__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .tk-search__grid { grid-template-columns: 1fr; }
    .tk-search__h1 { font-size: 32px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Search",
  "tag": "div",
  "class": "tk-search-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Search Our Catalog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find Your Perfect Hardware" },
    { "type": "textarea", "id": "suggestions", "label": "Popular suggestions (comma-separated)", "default": "Honey Bronze Knobs, Bar Pulls, Pemberton Collection, Brushed Nickel Pulls, Appliance Pulls, Serene Collection" }
  ]
}
{% endschema %}
