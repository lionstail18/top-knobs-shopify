<section class="tk-cat-grid">
  <div class="tk-cat-grid__head">
    <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2 class="tk-cat-grid__h2">{{ section.settings.heading | escape }}</h2>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="tk-cat-grid__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <a class="tk-cat-grid__card" href="{{ block.settings.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            <div class="tk-cat-grid__img-wrap">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    class: 'tk-cat-grid__img',
                    alt: block.settings.title | escape -}}
              {%- else -%}
                <div class="tk-cat-grid__img tk-cat-grid__img--placeholder"></div>
              {%- endif -%}
            </div>
            <p class="tk-cat-grid__name">{{ block.settings.title | escape }}</p>
            {%- if block.settings.count != blank -%}
              <p class="tk-cat-grid__count">{{ block.settings.count | escape }} styles</p>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{%- style -%}
  .tk-cat-grid {
    padding: var(--tk-section-y) var(--tk-page-x);
    background: var(--color-bg);
  }
  .tk-cat-grid__head {
    text-align: center;
    margin-bottom: 48px;
  }
  .tk-cat-grid__head .tk-eyebrow {
    margin: 0 0 10px;
  }
  .tk-cat-grid__h2 {
    font-family: var(--tk-font-heading);
    font-size: 40px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    line-height: 1.1;
  }
  .tk-cat-grid__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }
  .tk-cat-grid__card {
    display: block;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s ease;
    cursor: pointer;
  }
  .tk-cat-grid__card:hover {
    transform: translateY(-4px);
  }
  .tk-cat-grid__img-wrap {
    overflow: hidden;
    margin-bottom: 14px;
  }
  .tk-cat-grid__img {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
    object-position: center;
  }
  .tk-cat-grid__img--placeholder {
    background: var(--color-border);
  }
  .tk-cat-grid__name {
    font-family: var(--tk-font-heading);
    font-size: 19px;
    color: var(--color-text);
    margin: 0 0 4px;
    line-height: 1.2;
  }
  .tk-cat-grid__count {
    font-family: var(--tk-font-body);
    font-size: 11px;
    color: var(--color-accent);
    margin: 0;
  }
  @media (max-width: 1024px) {
    .tk-cat-grid__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .tk-cat-grid__grid { grid-template-columns: repeat(2, 1fr); }
    .tk-cat-grid__h2 { font-size: 32px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Category Grid",
  "tag": "div",
  "class": "tk-cat-grid-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Explore Our Range"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category name",
          "default": "Knobs"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Item count",
          "default": "1,200+"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Category Grid" }
  ]
}
{% endschema %}
