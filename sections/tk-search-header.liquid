<!-- ============================================================
  Top Knobs — Search Page Header (tk-search-header.liquid)

  Extracted from tk-search.liquid as part of Path B Searchanise migration.
  Renders the page hero ("Find Your Perfect Hardware") + native search form
  + "Popular:" suggestion chips when no query has been entered yet.

  The actual search results body is rendered by a sibling section in
  templates/search.json (Shopify's main-search.liquid), where Searchanise's
  app embed injects its filter sidebar + results widgets.
============================================================ -->

<div class="tk-search__header">
  <div class="tk-search__header-inner">
    <p class="tk-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1 class="tk-search__h1">{{ section.settings.heading | escape }}</h1>
    <form class="tk-search__form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input
        class="tk-search__input"
        name="q"
        type="search"
        placeholder="Search by name, collection, finish, or SKU…"
        value="{{ search.terms | escape }}"
        autocomplete="off">
      <button type="submit" class="tk-search__submit">Search</button>
    </form>
    {%- unless search.performed -%}
      <div class="tk-search__suggestions">
        <span class="tk-search__suggestions-label">Popular:</span>
        {%- assign suggestions = section.settings.suggestions | split: ',' -%}
        {%- for s in suggestions -%}
          <a class="tk-search__suggestion" href="{{ routes.search_url }}?q={{ s | strip | url_encode }}&type=product">{{ s | strip }}</a>
        {%- endfor -%}
      </div>
    {%- endunless -%}
  </div>
</div>

{%- style -%}
  .tk-search__header {
    padding: 56px var(--tk-page-x) 40px;
    background: var(--color-bg2);
    border-bottom: 1px solid var(--color-border);
  }
  .tk-search__header-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .tk-search__header .tk-eyebrow { margin: 0 0 12px; }
  .tk-search__h1 {
    font-family: var(--tk-font-heading);
    font-size: 44px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 24px;
    line-height: 1.05;
  }
  .tk-search__form {
    display: flex;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .tk-search__input {
    flex: 1;
    padding: 14px 16px;
    border: none;
    background: none;
    font-family: var(--tk-font-body);
    font-size: 14px;
    color: var(--color-text);
    outline: none;
  }
  .tk-search__submit {
    padding: 0 24px;
    background: var(--color-accent);
    border: none;
    color: #fff;
    font-family: var(--tk-font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .tk-search__suggestions {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    align-items: center;
  }
  .tk-search__suggestions-label {
    font-family: var(--tk-font-body);
    font-size: 11px;
    color: var(--color-text2);
  }
  .tk-search__suggestion {
    font-family: var(--tk-font-body);
    font-size: 11px;
    color: var(--color-accent);
    text-decoration: underline;
  }
  @media (max-width: 600px) {
    .tk-search__h1 { font-size: 32px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Search Header",
  "tag": "div",
  "class": "tk-search-header-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Search Our Catalog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find Your Perfect Hardware" },
    { "type": "textarea", "id": "suggestions", "label": "Popular suggestions (comma-separated)", "default": "Honey Bronze Knobs, Bar Pulls, Pemberton Collection, Brushed Nickel Pulls, Appliance Pulls, Serene Collection" }
  ],
  "presets": [
    { "name": "Search Header" }
  ]
}
{% endschema %}
